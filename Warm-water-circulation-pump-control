/** WW-Pumpe Steuerung für ioBroker
* Schaltet die Pumpe (Shelly) für eine vorgegebene Laufzeit oder manuell.
* Alle Datenpunkte werden unter 0_userdata.0.Heizung.WW-Pumpe angelegt.
*/

const exec = require('child_process').exec;

// =======================
// Datenpunkte
// =======================
const BASE = '0_userdata.0.Heizung.WW-Pumpe.';

const DP = {
    start: BASE + 'Start',
    duration: BASE + 'LaufzeitMin',
    remaining: BASE + 'RestlaufzeitMin',
    manual: BASE + 'Manuell',
    status: BASE + 'Status',
    lastReason: BASE + 'LetzterSchaltgrund',
    errorActive: BASE + 'FehlerAktiv',
    errorText: BASE + 'FehlerText',
    lastUpdateTs: BASE + 'LastUpdateTs',
    scriptVersion: BASE + 'ScriptVersion',

    shellySwitch: 'alias.0.Heizung.WW-Pumpe.SET',
    shellyOnline: 'alias.0.Heizung.WW-Pumpe.ONLINE',
    shellyButton: 'shelly.1.ble.38:39:8f:98:06:9f.button_1'
};

// =======================
// Zeiten
// =======================
const TIMES = {
    defaultDurationMin: 30,
    countdownIntervalMs: 1000
};

// =======================
// Parameter
// =======================
const PARAM = {
    scriptVersion: '1.1.1',
    minDurationMin: 1,
    maxDurationMin: 180,
    manualOnRemainingDisplayMin: 99,
    restartCmd: 'iobroker restart energiefluss-erweitert.2',
    restartAdapterAfterOff: true // notwendig, weil sich die Anzeige des Adapters nach Ablauf aufhängen kann
};

// =======================
// Interne Zustände
// =======================
let countdown = null;
let remainingSec = 0;

// =======================
// Datenpunkte anlegen
// =======================
function ensureState(id, initialValue, common) {
    if (!existsObject(id)) {
        createState(id, initialValue, common);
    } else {
        extendObject(id, { common });
    }
}

function ensureStateRO(id, initialValue, common) {
    ensureState(id, initialValue, { ...common, read: true, write: false });
}

function ensureStateRW(id, initialValue, common) {
    ensureState(id, initialValue, { ...common, read: true, write: true });
}

function initStates() {
    ensureStateRW(DP.start, false, { name: 'Pumpe starten', type: 'boolean', role: 'button' });
    ensureStateRW(DP.duration, TIMES.defaultDurationMin, { name: 'Laufzeit (min)', type: 'number', role: 'value', unit: 'min', min: PARAM.minDurationMin, max: PARAM.maxDurationMin });
    ensureStateRO(DP.remaining, 0, { name: 'Restlaufzeit (min)', type: 'number', role: 'value', unit: 'min' });
    ensureStateRW(DP.manual, 'auto', { name: 'Manuell', type: 'string', role: 'state', states: { auto: 'Auto', on: 'An', off: 'Aus' } });
    ensureStateRO(DP.status, 'Bereit', { name: 'Status', type: 'string', role: 'state' });
    ensureStateRO(DP.lastReason, '', { name: 'WW-Pumpe letzter Schaltgrund', type: 'string', role: 'text' });
    ensureStateRO(DP.errorActive, false, { name: 'WW-Pumpe Fehler aktiv', type: 'boolean', role: 'indicator' });
    ensureStateRO(DP.errorText, '', { name: 'WW-Pumpe Fehlertext', type: 'string', role: 'text' });
    ensureStateRO(DP.lastUpdateTs, 0, { name: 'WW-Pumpe letzte Aktualisierung (Unix ms)', type: 'number', role: 'value.time' });
    ensureStateRO(DP.scriptVersion, PARAM.scriptVersion, { name: 'Skriptversion', type: 'string', role: 'text' });
    setState(DP.scriptVersion, PARAM.scriptVersion, true);
}

// =======================
// Funktionen
// =======================
function touch() {
    setState(DP.lastUpdateTs, Date.now(), true);
}

function setStatus(text) {
    setState(DP.status, text, true);
    touch();
}

function setReason(reason) {
    setState(DP.lastReason, reason, true);
    log(`[WW-Pumpe] ${reason}`, 'info');
    touch();
}

function setError(active, text = '') {
    setState(DP.errorActive, active, true);
    setState(DP.errorText, text, true);
    touch();
}

function isShellyOnline() {
    return !!getState(DP.shellyOnline)?.val;
}

function getManualMode() {
    const mode = String(getState(DP.manual)?.val || 'auto');
    return ['auto', 'on', 'off'].includes(mode) ? mode : 'auto';
}

function getConfiguredDurationMin() {
    const value = Number(getState(DP.duration)?.val);
    if (isNaN(value)) return TIMES.defaultDurationMin;
    return Math.round(Math.min(PARAM.maxDurationMin, Math.max(PARAM.minDurationMin, value)));
}

function syncDurationBounds() {
    const current = Number(getState(DP.duration)?.val);
    const sanitized = getConfiguredDurationMin();
    if (isNaN(current) || current !== sanitized) {
        setState(DP.duration, sanitized, true);
    }
}

function startTimer(minutes) {
    if (getManualMode() !== 'auto') return;
    syncDurationBounds();

    const durationMin = Math.round(Math.min(PARAM.maxDurationMin, Math.max(PARAM.minDurationMin, Number(minutes) || TIMES.defaultDurationMin)));
    if (!isShellyOnline()) {
        setError(true, 'Shelly offline');
        setStatus('Offline');
        setReason('Start abgebrochen: Shelly offline');
        return;
    }

    setError(false);
    remainingSec = durationMin * 60;
    setState(DP.shellySwitch, true);
    setReason(`Timer gestartet für ${durationMin} min`);
    updateRemaining();

    if (countdown) clearInterval(countdown);
    countdown = setInterval(() => {
        remainingSec--;
        updateRemaining();
    }, TIMES.countdownIntervalMs);
}

function updateRemaining() {
    const remainingMin = Math.ceil(Math.max(0, remainingSec) / 60);
    setState(DP.remaining, remainingMin, true);

    if (remainingSec <= 0) {
        stopTimer();
        turnOffPump('Timer abgelaufen');
        setStatus('Bereit');
        setState(DP.remaining, getConfiguredDurationMin(), true);
    } else {
        setStatus('EIN: ' + remainingMin);
    }
}

function stopTimer() {
    if (countdown) {
        clearInterval(countdown);
        countdown = null;
    }
    remainingSec = 0;
}

function turnOffPump(reason = 'Pumpe AUS') {
    const wasOn = !!getState(DP.shellySwitch)?.val;
    setState(DP.shellySwitch, false);
    setReason(reason);
    if (wasOn && PARAM.restartAdapterAfterOff) exec(PARAM.restartCmd);
}

function handleShellyButton(obj) {
    if (!obj?.state?.val) return;
    startTimer(getConfiguredDurationMin());
}

initStates();

// =======================
// Events
// =======================
on({ id: DP.start, val: true }, () => {
    startTimer(getConfiguredDurationMin());
    setState(DP.start, false, true);
});

on({ id: DP.shellyButton, change: 'ne' }, handleShellyButton);

on({ id: DP.manual, change: 'ne' }, obj => {
    const mode = String(obj.state.val || 'auto');
    stopTimer();

    if (mode === 'on') {
        if (isShellyOnline()) {
            setError(false);
            setState(DP.shellySwitch, true);
            setStatus('Manuell AN');
            setReason('Manuell AN');
            setState(DP.remaining, PARAM.manualOnRemainingDisplayMin, true);
        } else {
            setError(true, 'Shelly offline');
            setStatus('Offline');
            setReason('Manuell AN nicht möglich: Shelly offline');
            setState(DP.manual, 'auto', true);
            setState(DP.remaining, getConfiguredDurationMin(), true);
        }
    } else if (mode === 'off') {
        setError(false);
        turnOffPump('Manuell AUS');
        setStatus('Manuell AUS');
        setState(DP.remaining, 0, true);
    } else {
        setError(false);
        turnOffPump('Automatik bereit');
        setStatus('Bereit');
        setState(DP.remaining, getConfiguredDurationMin(), true);
    }
});

on({ id: DP.duration, change: 'ne' }, obj => {
    syncDurationBounds();
    if (getManualMode() === 'auto' && !countdown) {
        setState(DP.remaining, getConfiguredDurationMin(), true);
    }
});

on({ id: DP.shellyOnline, change: 'ne' }, obj => {
    if (!obj.state.val) {
        setError(true, 'Shelly offline');
        setStatus('Offline');
        setReason('Shelly offline');
    } else {
        setError(false);
        if (!countdown && getManualMode() === 'auto') {
            setStatus('Bereit');
            setReason('Shelly wieder online');
            setState(DP.remaining, getConfiguredDurationMin(), true);
        }
    }
});

// =======================
// Init
// =======================
stopTimer();
syncDurationBounds();

const initMode = getManualMode();
setState(DP.manual, initMode, true);

if (initMode === 'on') {
    if (isShellyOnline()) {
        setError(false);
        setState(DP.shellySwitch, true);
        setStatus('Manuell AN');
        setReason('Start: Manuell AN wiederhergestellt');
        setState(DP.remaining, PARAM.manualOnRemainingDisplayMin, true);
    } else {
        setError(true, 'Shelly offline');
        setState(DP.manual, 'auto', true);
        setStatus('Offline');
        setReason('Start: Manuell AN wegen Shelly offline zurückgesetzt');
        setState(DP.remaining, getConfiguredDurationMin(), true);
    }
} else if (initMode === 'off') {
    setError(false);
    turnOffPump('Start: Manuell AUS');
    setStatus('Manuell AUS');
    setState(DP.remaining, 0, true);
} else {
    if (!isShellyOnline()) {
        setError(true, 'Shelly offline');
        setStatus('Offline');
        setReason('Start: Shelly offline');
    } else {
        setError(false);
        turnOffPump('Start: Automatik bereit');
        setStatus('Bereit');
        setState(DP.remaining, getConfiguredDurationMin(), true);
    }
}

onStop(() => {
    stopTimer();
}, 200);
