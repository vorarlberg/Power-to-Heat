/**
 * WW-Pumpe Steuerung für ioBroker
 * Schaltet die Pumpe (Shelly) für eine vorgegebene Laufzeit oder manuell.
 * Alle Datenpunkte werden unter 0_userdata.0.Heizung.WW-Pumpe angelegt.
 */

// ===== KONFIGURATION =====
const BASE = '0_userdata.0.Heizung.WW-Pumpe.';

const SHELLY_SWITCH = 'shelly.1.shellyplusplugs#e465b8b75fdc#1.Relay0.Switch';
const SHELLY_ONLINE = 'shelly.1.shellyplusplugs#e465b8b75fdc#1.online';

const DEFAULT_DURATION_MIN = 30;           // Standardlaufzeit bei Neuerstellung
const COUNTDOWN_INTERVAL_MS = 1000;        // Auflösung Restlaufzeit

const DP = {
    start: BASE + 'Start',            // Button zum Starten
    duration: BASE + 'LaufzeitMin',   // Vorgabe der Laufzeit in Minuten
    remaining: BASE + 'RestlaufzeitMin', // Ausgabe der Restlaufzeit in Minuten
    manual: BASE + 'Manuell',         // 'auto' | 'on' | 'off'
    status: BASE + 'Status'           // Statusausgabe
};

// ===== DATENPUNKTE ANLEGEN =====
createState(DP.start, false, {name: 'Pumpe starten', type: 'boolean', role: 'button', read: true, write: true});
createState(DP.duration, DEFAULT_DURATION_MIN, {name: 'Laufzeit (min)', type: 'number', role: 'value', unit: 'min', read: true, write: true});
createState(DP.remaining, 0, {name: 'Restlaufzeit (min)', type: 'number', role: 'value', unit: 'min', read: true, write: false});
createState(DP.manual, 'auto', {name: 'Manuell', type: 'string', role: 'state', read: true, write: true, states: {auto: 'Auto', on: 'An', off: 'Aus'}});
createState(DP.status, 'Bereit', {name: 'Status', type: 'string', role: 'state', read: true, write: false});

// ===== VARIABLEN =====
let countdown = null;
let remainingSec = 0;

// ===== FUNKTIONEN =====
function startTimer(minutes) {
    if (getState(DP.manual).val !== 'auto') return;
    if (!getState(SHELLY_ONLINE).val) {
        log('WW-Pumpe: Shelly offline, Start abgebrochen');
        return;
    }
    remainingSec = Math.round(minutes * 60);
    setState(SHELLY_SWITCH, true);
    setState(DP.status, 'L\u00e4uft mit Restzeit', true);
    updateRemaining();
    if (countdown) clearInterval(countdown);
    countdown = setInterval(() => {
        remainingSec--;
        updateRemaining();
    }, COUNTDOWN_INTERVAL_MS);
}

function updateRemaining() {
    setState(DP.remaining, Math.max(0, remainingSec) / 60);
    if (remainingSec <= 0) {
        stopTimer();
        setState(SHELLY_SWITCH, false);
        setState(DP.status, 'Bereit', true);

    }
}

function stopTimer() {
    if (countdown) {
        clearInterval(countdown);
        countdown = null;
    }
    remainingSec = 0;

}

// ===== EVENTS =====
on({id: DP.start, val: true}, obj => {
    const minutes = parseFloat(getState(DP.duration).val) || 0;
    startTimer(minutes);
    setState(DP.start, false, true); // Button zur\u00fccksetzen
});

on({id: DP.manual, change: 'ne'}, obj => {
    const mode = obj.state.val;
    stopTimer();
    if (mode === 'on') {
        if (getState(SHELLY_ONLINE).val) {
            setState(SHELLY_SWITCH, true);
            setState(DP.status, 'Manuell AN', true);

        } else {
            log('WW-Pumpe: Shelly offline, Manuell AN nicht m\u00f6glich');
            setState(DP.manual, 'auto', true);
            setState(DP.status, 'Bereit', true);

        }
    } else if (mode === 'off') {
        setState(SHELLY_SWITCH, false);
        setState(DP.status, 'Manuell AUS', true);

    }
});

// ===== INIT =====
stopTimer();
const initMode = getState(DP.manual).val || 'auto';
setState(DP.manual, initMode, true);
if (initMode === 'on') {
    if (getState(SHELLY_ONLINE).val) {
        setState(SHELLY_SWITCH, true);
        setState(DP.status, 'Manuell AN', true);

    }
} else if (initMode === 'off') {
    setState(SHELLY_SWITCH, false);
    setState(DP.status, 'Manuell AUS', true);

}

onStop(() => {
    stopTimer();
}, 200);

