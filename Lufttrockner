/**
 * Lufttrockner Steuerung - ioBroker
 *
 * Funktionen:
 * - VIS-Betriebsmodus per Auswahl: Auto / Ein / Aus
 * - Shelly Plug S Gen3 schaltet den Lufttrockner
 * - Ist-Rückmeldung über Leistungsaufnahme
 * - PV-Überschuss-Freigabe mit 15-Minuten Ein-/Ausschaltverzögerung
 * - ab Pufferspeicher >= 60 °C fordert der Lufttrockner nur bei Bedarf eine Heizstab-Reserve an
 * - der Heizstab läuft mit restlichem PV-Überschuss weiter, solange genug PV-Strom für den Lufttrockner bleibt
 * - Tank-voll-/Gerät-aus-Erkennung per Leistungsabfall inkl. Pushover
 * - nach der 3. automatischen PV-Abschaltung am Tag Sperre bis Mitternacht
 */

// =======================
// Datenpunkte
// =======================
const DP = {
    visBetriebsmodus: '0_userdata.0.Heizung.Lufttrockner.Betriebsmodus',
    visFreigabeAlt: '0_userdata.0.Heizung.Lufttrockner.Freigabe',
    istLaeuft: '0_userdata.0.Heizung.Lufttrockner.IstLaeuft',
    status: '0_userdata.0.Heizung.Lufttrockner.Status',
    letzterSchaltgrund: '0_userdata.0.Heizung.Lufttrockner.LetzterSchaltgrund',
    pvGenugSeit: '0_userdata.0.Heizung.Lufttrockner.PVGenugSeit',
    pvZuWenigSeit: '0_userdata.0.Heizung.Lufttrockner.PVZuWenigSeit',
    pvLetzteBewertung: '0_userdata.0.Heizung.Lufttrockner.PVLetzteBewertung',
    abschaltungenHeute: '0_userdata.0.Heizung.Lufttrockner.AbschaltungenHeute',
    tagessperreAktiv: '0_userdata.0.Heizung.Lufttrockner.TagessperreAktiv',
    tankMeldungAktiv: '0_userdata.0.Heizung.Lufttrockner.TankMeldungAktiv',
    heizstabPauseAktiv: '0_userdata.0.Heizung.Lufttrockner.HeizstabPauseAktiv',
    scriptVersion: '0_userdata.0.Heizung.Lufttrockner.ScriptVersion',

    pvUeberschussW: '0_userdata.0.Strom.Netzeinspeisung',
    pufferTempC: 'modbus.2.holdingRegisters.1.1030_Temp_2',
    heizstabPauseRequest: '0_userdata.0.Heizstab.V2.ExterneAnforderung.Lufttrockner_Pause_Heizstab',
    heizstabPauseAktivHauptskript: '0_userdata.0.Heizstab.V2.ExterneAnforderung.Lufttrockner_Pause_Aktiv',
    heizstabIstLeistungW: 'modbus.2.holdingRegisters.1.1000_Power',

    shellyOnline: 'shelly.1.shellyplugsg3#d885ac17fd24#1.online',
    shellySwitch: 'shelly.1.shellyplugsg3#d885ac17fd24#1.Relay0.Switch',
    shellyPowerW: 'shelly.1.shellyplugsg3#d885ac17fd24#1.Relay0.Power'
};

// =======================
// Zeiten
// =======================
const TIMES = {
    regelIntervallMs: 30000,
    pvEinVerzoegerungMs: 15 * 60 * 1000,
    pvAusVerzoegerungMs: 15 * 60 * 1000,
    heizstabFreigabeNachlaufMs: 2 * 60 * 1000,
    tankVollErkennungMs: 2 * 60 * 1000,
    startLeistungsIgnorierenMs: 60 * 1000,
    mitternachtResetCron: '0 0 * * *'
};

// =======================
// Parameter
// =======================
const PARAM = {
    scriptVersion: '1.3.1',
    minPvUeberschussW: 1000,
    geraeteLeistungW: 800,
    runningPowerMinW: 100,
    pufferVorrangAbC: 60,
    heizstabReserveFreigabeHystereseW: 200,
    maxPvAbschaltungenProTag: 3,
    pushoverEnabled: true,
    pushoverAdapter: 'pushover',
    pushoverTitle: 'Lufttrockner',
    pushoverSound: ''
};

// =======================
// Interne Zustände
// =======================
let commandedOn = null;
let heizstabPauseRequested = false;
let heizstabPauseKeepUntil = 0;
let lowPowerSince = null;
let lastSwitchOnAt = 0;
let pvEnoughSince = null;
let pvLowSince = null;
let dailyStopCount = 0;
let dayLockActive = false;
let tankNotificationActive = false;

// =======================
// Datenpunkte anlegen
// =======================
function ensureState(id, initialValue, common) {
    if (!existsObject(id)) {
        createState(id, initialValue, common);
    } else {
        extendObject(id, { common });
    }
}

function initStates() {
    const defaultMode = existsObject(DP.visFreigabeAlt) && getState(DP.visFreigabeAlt)?.val ? 'Auto' : 'Aus';
    ensureState(DP.visBetriebsmodus, defaultMode, {
        name: 'Lufttrockner Betriebsmodus VIS',
        type: 'string',
        role: 'text',
        read: true,
        write: true,
        states: {
            Auto: 'Auto',
            Ein: 'Ein',
            Aus: 'Aus'
        }
    });
    ensureState(DP.istLaeuft, false, { name: 'Lufttrockner läuft', type: 'boolean', role: 'indicator.working', read: true, write: false });
    ensureState(DP.status, 'Initialisierung', { name: 'Lufttrockner Status', type: 'string', role: 'text', read: true, write: false });
    ensureState(DP.letzterSchaltgrund, '', { name: 'Lufttrockner letzter Schaltgrund', type: 'string', role: 'text', read: true, write: false });
    ensureState(DP.pvGenugSeit, '', { name: 'Lufttrockner PV genug seit', type: 'string', role: 'text', read: true, write: false });
    ensureState(DP.pvZuWenigSeit, '', { name: 'Lufttrockner PV zu wenig seit', type: 'string', role: 'text', read: true, write: false });
    ensureState(DP.pvLetzteBewertung, '', { name: 'Lufttrockner letzte PV-Bewertung mit Zeitpunkt', type: 'string', role: 'text', read: true, write: false });
    ensureState(DP.abschaltungenHeute, 0, { name: 'Lufttrockner PV-Abschaltungen heute', type: 'number', role: 'value', read: true, write: false });
    ensureState(DP.tagessperreAktiv, false, { name: 'Lufttrockner Tagessperre aktiv', type: 'boolean', role: 'indicator', read: true, write: false });
    ensureState(DP.tankMeldungAktiv, false, { name: 'Lufttrockner Tankmeldung aktiv', type: 'boolean', role: 'indicator', read: true, write: false });
    ensureState(DP.heizstabPauseAktiv, false, { name: 'Lufttrockner Heizstab-Pause aktiv', type: 'boolean', role: 'indicator', read: true, write: false });
    ensureState(DP.scriptVersion, PARAM.scriptVersion, { name: 'Lufttrockner Skriptversion', type: 'string', role: 'text', read: true, write: false });
    setState(DP.scriptVersion, PARAM.scriptVersion, true);
}

function readNumber(id, fallback = 0) {
    const value = Number(getState(id)?.val);
    return isNaN(value) ? fallback : value;
}

function getVisMode() {
    const mode = String(getState(DP.visBetriebsmodus)?.val || 'Aus');
    return ['Auto', 'Ein', 'Aus'].includes(mode) ? mode : 'Aus';
}

function isAutoMode() {
    return getVisMode() === 'Auto';
}

function isOnMode() {
    return getVisMode() === 'Ein';
}

function isDryerEnabledByMode() {
    return isAutoMode() || isOnMode();
}

function isShellyOnline() {
    return !!getState(DP.shellyOnline)?.val;
}

function isShellyOn() {
    return !!getState(DP.shellySwitch)?.val;
}

function getDryerPower() {
    return readNumber(DP.shellyPowerW, 0);
}

function isDryerRunning() {
    return getDryerPower() >= PARAM.runningPowerMinW;
}

function getHeizstabPower() {
    return readNumber(DP.heizstabIstLeistungW, 0);
}

function getEffectivePvSurplusW(running, includeHeizstab = false) {
    const surplus = readNumber(DP.pvUeberschussW, 0);
    const dryerPower = running ? getDryerPower() : 0;
    const heizstabPower = includeHeizstab ? getHeizstabPower() : 0;
    return surplus + dryerPower + heizstabPower;
}

function setStatus(text) {
    setState(DP.status, text, true);
}

function setReason(reason) {
    setState(DP.letzterSchaltgrund, reason, true);
    log(`[Lufttrockner] ${reason}`, 'info');
}

function sendPushover(message) {
    if (!PARAM.pushoverEnabled) return;

    const payload = {
        title: PARAM.pushoverTitle,
        message
    };

    if (PARAM.pushoverSound) payload.sound = PARAM.pushoverSound;
    sendTo(PARAM.pushoverAdapter, payload);
}

function setDryer(on, reason) {
    if (!isShellyOnline()) {
        commandedOn = null;
        setReason(`Schaltbefehl nicht gesendet: Shelly offline (${reason})`);
        return;
    }

    if (commandedOn === on && isShellyOn() === on) return;

    setState(DP.shellySwitch, on, false);
    commandedOn = on;
    setReason(reason);

    if (on) {
        lastSwitchOnAt = Date.now();
        lowPowerSince = null;
        tankNotificationActive = false;
        setState(DP.tankMeldungAktiv, false, true);
    }
}

function setHeizstabPauseRequest(on, reason) {
    if (heizstabPauseRequested === on && !!getState(DP.heizstabPauseRequest)?.val === on) return;

    setState(DP.heizstabPauseRequest, on, false);
    heizstabPauseRequested = on;
    setState(DP.heizstabPauseAktiv, on, true);
    setReason(reason);
}

function updateHeizstabPriority(autoMode, locked, pufferTemp, effectiveSurplus, potentialSurplus, dryerDemandActive) {
    const now = Date.now();
    const enoughPotentialPv = potentialSurplus >= PARAM.minPvUeberschussW;
    const actualSurplusTooLow = effectiveSurplus < (PARAM.minPvUeberschussW + PARAM.heizstabReserveFreigabeHystereseW);

    if (!autoMode || locked) {
        heizstabPauseKeepUntil = 0;
        setHeizstabPauseRequest(false, !autoMode ? 'Heizstab-Pause beendet: Betriebsmodus nicht Auto' : 'Heizstab-Pause beendet: Tagessperre aktiv');
        return false;
    }
    const shouldRequest = autoMode
        && !locked
        && pufferTemp >= PARAM.pufferVorrangAbC
        && enoughPotentialPv
        && actualSurplusTooLow
        && dryerDemandActive;

    if (shouldRequest) {
        heizstabPauseKeepUntil = now + TIMES.heizstabFreigabeNachlaufMs;
        setHeizstabPauseRequest(true, `Heizstab-Reserve beim Hauptskript angefordert: Lufttrockner braucht ${PARAM.minPvUeberschussW} W, aktuell frei ${Math.round(effectiveSurplus)} W, PV-Potential ${Math.round(potentialSurplus)} W`);
        return true;
    }

    if (heizstabPauseRequested && now < heizstabPauseKeepUntil && actualSurplusTooLow) {
        return true;
    }

    setHeizstabPauseRequest(false, 'Heizstab-Reserve beim Hauptskript beendet: genug freier PV-Überschuss für Lufttrockner');
    return false;
}


function resetDailyLock() {
    dailyStopCount = 0;
    dayLockActive = false;
    setState(DP.abschaltungenHeute, dailyStopCount, true);
    setState(DP.tagessperreAktiv, false, true);
    setReason('Tageszähler zurückgesetzt');
}

function registerPvStop() {
    dailyStopCount += 1;
    setState(DP.abschaltungenHeute, dailyStopCount, true);

    if (dailyStopCount >= PARAM.maxPvAbschaltungenProTag) {
        dayLockActive = true;
        setState(DP.tagessperreAktiv, true, true);
        setDryer(false, `PV-Abschaltung ${dailyStopCount}/${PARAM.maxPvAbschaltungenProTag}: Tagessperre bis Mitternacht aktiv`);
    } else {
        setDryer(false, `PV-Überschuss länger als ${TIMES.pvAusVerzoegerungMs / 60000} min zu gering (${dailyStopCount}/${PARAM.maxPvAbschaltungenProTag})`);
    }
}

function parseStoredTimestamp(id) {
    const stored = String(getState(id)?.val || '');
    const timestamp = Date.parse(stored);
    return isNaN(timestamp) ? null : timestamp;
}

function loadPvTimersFromStates() {
    pvEnoughSince = parseStoredTimestamp(DP.pvGenugSeit);
    pvLowSince = parseStoredTimestamp(DP.pvZuWenigSeit);

    if (pvEnoughSince && pvLowSince) {
        if (pvEnoughSince >= pvLowSince) {
            pvLowSince = null;
        } else {
            pvEnoughSince = null;
        }
    }
}

function updatePvTimers(pvEnough) {
    const now = Date.now();
    const nowIso = new Date(now).toISOString();
    const bewertung = pvEnough ? 'Genug' : 'ZuWenig';

    if (pvEnough) {
        if (!pvEnoughSince) pvEnoughSince = now;
        pvLowSince = null;
    } else {
        if (!pvLowSince) pvLowSince = now;
        pvEnoughSince = null;
    }

    setState(DP.pvGenugSeit, pvEnoughSince ? new Date(pvEnoughSince).toISOString() : '', true);
    setState(DP.pvZuWenigSeit, pvLowSince ? new Date(pvLowSince).toISOString() : '', true);
    setState(DP.pvLetzteBewertung, `${bewertung} (${nowIso})`, true);
}

function checkTankFull(running, shellyOn) {
    const now = Date.now();
    const startGraceActive = shellyOn && now - lastSwitchOnAt < TIMES.startLeistungsIgnorierenMs;

    if (shellyOn && !running && !startGraceActive) {
        if (!lowPowerSince) lowPowerSince = now;
        if (!tankNotificationActive && now - lowPowerSince >= TIMES.tankVollErkennungMs) {
            tankNotificationActive = true;
            setState(DP.tankMeldungAktiv, true, true);
            setDryer(false, 'Lufttrockner ohne Leistungsaufnahme - vermutlich Tank voll oder Gerät automatisch aus');
            sendPushover('Lufttrockner hat keine Leistungsaufnahme mehr. Bitte Tank prüfen/leeren.');
        }
    } else {
        lowPowerSince = null;
        if (running && tankNotificationActive) {
            tankNotificationActive = false;
            setState(DP.tankMeldungAktiv, false, true);
        }
    }
}

function regulate() {
    const autoMode = isAutoMode();
    const onMode = isOnMode();
    const dryerEnabled = isDryerEnabledByMode();
    const shellyOnline = isShellyOnline();
    const shellyOn = shellyOnline && isShellyOn();
    const running = shellyOnline && isDryerRunning();
    const pufferTemp = readNumber(DP.pufferTempC, -999);
    const effectiveSurplus = getEffectivePvSurplusW(running);
    const potentialSurplus = getEffectivePvSurplusW(running, true);
    const dryerDemandActive = autoMode && (!shellyOn || running);
    const heizstabPauseRequestedNow = updateHeizstabPriority(autoMode, dayLockActive, pufferTemp, effectiveSurplus, potentialSurplus, dryerDemandActive);
    const pvForDecision = heizstabPauseRequestedNow ? potentialSurplus : effectiveSurplus;
    const pvEnough = pvForDecision >= PARAM.minPvUeberschussW;
    const now = Date.now();

    commandedOn = shellyOn;
    setState(DP.istLaeuft, running, true);

    if (!shellyOnline) {
        pvEnoughSince = null;
        pvLowSince = null;
        lowPowerSince = null;
        setState(DP.pvGenugSeit, '', true);
        setState(DP.pvZuWenigSeit, '', true);
        setState(DP.pvLetzteBewertung, '', true);
        setHeizstabPauseRequest(false, 'Heizstab-Pause beendet: Shelly Lufttrockner offline');
        setStatus('Aus: Shelly Lufttrockner offline');
        return;
    }

    updatePvTimers(pvEnough);
    checkTankFull(running, shellyOn);

    if (!dryerEnabled) {
        if (tankNotificationActive) {
            tankNotificationActive = false;
            setState(DP.tankMeldungAktiv, false, true);
        }
        setDryer(false, 'Betriebsmodus Aus');
        setStatus('Aus: Betriebsmodus Aus');
        return;
    }

    if (onMode && tankNotificationActive) {
        setDryer(false, 'Lufttrockner bleibt aus: Tankmeldung aktiv');
        setStatus('Aus: Tankmeldung aktiv - bitte Tank prüfen/leeren und danach Betriebsmodus Aus und wieder Ein wählen');
        return;
    }

    if (onMode) {
        setDryer(true, 'Betriebsmodus Ein: manuell eingeschaltet');
        setStatus(`Ein: Betriebsmodus Ein, Leistung ${Math.round(getDryerPower())} W`);
        return;
    }

    if (dayLockActive) {
        setDryer(false, 'Tagessperre aktiv');
        setStatus('Aus: Tagessperre bis Mitternacht aktiv');
        return;
    }

    if (shellyOn) {
        if (!pvEnough && pvLowSince && now - pvLowSince >= TIMES.pvAusVerzoegerungMs) {
            registerPvStop();
            setStatus('Aus: PV-Überschuss zu lange zu gering');
            return;
        }

        setStatus(`Ein: PV effektiv ${Math.round(effectiveSurplus)} W, PV-Potential ${Math.round(potentialSurplus)} W, Leistung ${Math.round(getDryerPower())} W`);
        return;
    }

    if (pvEnough && pvEnoughSince && now - pvEnoughSince >= TIMES.pvEinVerzoegerungMs) {
        setDryer(true, `PV-Überschuss länger als ${TIMES.pvEinVerzoegerungMs / 60000} min ausreichend`);
        setStatus('Ein: PV-Überschuss ausreichend');
        return;
    }

    setStatus(`Warten: PV effektiv ${Math.round(effectiveSurplus)} W, PV-Potential ${Math.round(potentialSurplus)} W von ${PARAM.minPvUeberschussW} W benötigt`);
}

initStates();
loadPvTimersFromStates();
dailyStopCount = readNumber(DP.abschaltungenHeute, 0);
dayLockActive = !!getState(DP.tagessperreAktiv)?.val;
tankNotificationActive = !!getState(DP.tankMeldungAktiv)?.val;
heizstabPauseRequested = !!getState(DP.heizstabPauseRequest)?.val;

schedule(TIMES.mitternachtResetCron, resetDailyLock);
schedule(`*/${Math.max(1, Math.round(TIMES.regelIntervallMs / 1000))} * * * * *`, regulate);
on({ id: [DP.visBetriebsmodus, DP.pvUeberschussW, DP.shellyOnline, DP.shellyPowerW, DP.shellySwitch, DP.pufferTempC, DP.heizstabIstLeistungW], change: 'ne' }, regulate);

regulate();
