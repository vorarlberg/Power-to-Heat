/**
 * Speicherladepumpe Steuerung - ioBroker
 * inkl. Debounce + GPIO-Test bei Scriptstart
 */

// =======================
// Datenpunkte
// =======================
const DP_MODE         = '0_userdata.0.Heizstab.V2.Regelung.Betriebsmodus';
// Soll/Freigabe aus Kessel/Logik (Unterstützungsbetrieb)
const DP_SHELLY_INPUT = 'shelly.1.shellyprorgbwwpm#ece334f93c48#1.Input1.Status';
// Ist-Rückmeldung (Schütz): hängt direkt am Schütz
const DP_SHELLY_IST   = 'shelly.1.shellyprorgbwwpm#ece334f93c48#1.Input3.Status'; // Ist-Zustand der Pumpe

const DP_SHELLY_ONLINE = 'shelly.1.shellyprorgbwwpm#ece334f93c48#1.online';

const DP_PUMP_ERROR    = '0_userdata.0.Heizung.Speicherladepumpe.FehlerShellyOffline'; // boolean

const DP_WW_ACTUAL    = 'alias.0.Heizung.Speicher_Warmwasser.ACTUAL';
const DP_PUFFER_TEMP  = 'modbus.2.holdingRegisters.1.1030_Temp_2'; // Pufferspeicher-Temperatur
const DP_WW_TARGET    = '0_userdata.0.Heizstab.V2.Parameter.WW_Zieltemperatur';
const DP_HEIZSTAB_AKTIV = '0_userdata.0.Heizstab.V2.Regelung.AKTIV'; // true=Heizstab-Regelung aktiv
const DP_HEIZSTAB_IST_LEISTUNG = 'modbus.2.holdingRegisters.1.1000_Power'; // echte Heizstab-Leistung

const DP_GPIO17       = '0_userdata.0.System.GPIO.GPIO17';
const DP_GPIO18       = '0_userdata.0.System.GPIO.GPIO18';

const DP_PUMP_STATE   = '0_userdata.0.Heizung.Speicherladepumpe.Status';
const DP_PUMP_MANUAL_MODE = '0_userdata.0.Heizung.Speicherladepumpe.ManualMode'; // string: "AUTO" | "ON" | "OFF"

const DP_PUMP_BYPASS  = 'shelly.1.shellyprorgbwwpm#ece334f93c48#1.RGB0.Switch'; // boolean: Schlüssel-Schalter, Pumpe wird vom Kessel angesteuert

const DP_PUMP_IST     = '0_userdata.0.Heizung.Speicherladepumpe.Ist'; // boolean: rückgemeldeter Pumpenzustand (Schütz)
const DP_PUMP_SOLL_IST_FEHLER = '0_userdata.0.Heizung.Speicherladepumpe.SollIstFehler'; // boolean: Soll/Ist Abweichung (nur wenn nicht überbrückt)
const DP_PUMP_SAFETY_ACTIVE = '0_userdata.0.Heizung.Speicherladepumpe.SicherheitsabschaltungAktiv'; // boolean: Sicherheits-/Sensor-Fail-Safe aktiv
const DP_PUMP_SAFETY_ON_TEMP = '0_userdata.0.Heizung.Speicherladepumpe.Parameter.SicherheitsabschaltungEin'; // number °C: Abschaltung ab dieser WW-Temperatur
const DP_PUMP_SAFETY_OFF_TEMP = '0_userdata.0.Heizung.Speicherladepumpe.Parameter.SicherheitsabschaltungAus'; // number °C: Freigabe ab/unter dieser WW-Temperatur
const DP_SCRIPT_VERSION = '0_userdata.0.Heizung.Speicherladepumpe.scriptVersion';

const SCRIPT_VERSION = '1.2.5';

// =======================
// Parameter
// =======================
const ON_BELOW_TEMP   = 51; // Fallback-Einschaltgrenze, falls WW-Zieltemperatur nicht lesbar ist
const OFF_ABOVE_TEMP  = 55; // Fallback-Ziel-/Ausschaltgrenze, falls WW-Zieltemperatur nicht lesbar ist
const MAX_OVER_TEMP_ON_DEFAULT  = 60; // Default: Sicherheitsabschaltung EIN ab dieser Temperatur
const MAX_OVER_TEMP_OFF_DEFAULT = 58; // Default: Sicherheitsfreigabe erst ab/unter dieser Temperatur
const WW_TEMP_VALID_MIN = 0; // darunter gilt der WW-Fühler als ungültig -> Fail-Safe AUS
const WW_TEMP_VALID_MAX = 95; // darüber gilt der WW-Fühler als ungültig -> Fail-Safe AUS

const DEBOUNCE_SHELLY_MS = 1000;
const DEBOUNCE_IST_MS     = 500;  // Entprellung Ist-Rückmeldung
const DEBOUNCE_TEMP_MS   = 10000;
const GPIO_TEST_DELAY_MS = 500;
const IST_INVERT          = false; // auf true setzen, falls der Kontakt logisch invertiert ist (z.B. NC)
const HEIZSTAB_RUNNING_MIN_W = 100; // ab dieser Ist-Leistung gilt der Heizstab als laufend

const SHELLY_OFFLINE_TIMEOUT_MS = 10000;

createState(DP_SCRIPT_VERSION, SCRIPT_VERSION, {
    name: 'Speicherladepumpe - Skriptversion',
    type: 'string',
    role: 'text',
    read: true,
    write: false
});
// createState aktualisiert bestehende Datenpunkte nicht. Deshalb die Version
// bei jedem Skriptstart aktiv veröffentlichen, damit das Hauptskript
// Versionsabweichungen zuverlässig erkennt.
setState(DP_SCRIPT_VERSION, SCRIPT_VERSION, true);

// =======================
// Interne Zustände
// =======================
let pumpIsOn = null;
let shellyTimer = null;
let tempTimer   = null;
let istTimer    = null;

let shellyOfflineTimer = null;
let shellyOfflineFaultActive = false;
let overTempActive = false;
let waitForPufferDeltaAfterEqualized = false;

// =======================
// Pumpensteuerung
// =======================
function setPump(on, reason = '') {
    if (reason) setState(DP_PUMP_LAST_REASON, reason, true);
    if (pumpIsOn === on) return;

    if (on) {
        setState(DP_GPIO17, true,  true);
        setState(DP_GPIO18, false, true);
        pumpIsOn = true;
        setState(DP_PUMP_STATE, true, true);
        log('[Pumpe] EIN', 'info');
        updateSollIst('setPump');
    } else {
        setState(DP_GPIO17, false, true);
        setState(DP_GPIO18, true,  true);
        pumpIsOn = false;
        setState(DP_PUMP_STATE, false, true);
        log('[Pumpe] AUS', 'info');
        updateSollIst('setPump');
    }
}

function getMode() {
    return String(getState(DP_MODE)?.val ?? '');
}

function isBypassActive() {
    return !!getState(DP_PUMP_BYPASS)?.val;
}

function readPumpIst() {
    const raw = !!getState(DP_SHELLY_IST)?.val;
    return IST_INVERT ? !raw : raw;
}

function readTemperature(dp) {
    const raw = getState(dp)?.val;
    const value = Number(raw);
    return { raw, value, valid: !isNaN(value) };
}

function isValidWwTemperature(value) {
    return !isNaN(value) && value >= WW_TEMP_VALID_MIN && value <= WW_TEMP_VALID_MAX;
}

function setSafetyActive(active) {
    setState(DP_PUMP_SAFETY_ACTIVE, active, true);
}

function getNumberStateOrDefault(dp, defaultValue) {
    const value = Number(getState(dp)?.val);
    return isNaN(value) ? defaultValue : value;
}

function getSafetyTemperatures() {
    const onTemp = getNumberStateOrDefault(DP_PUMP_SAFETY_ON_TEMP, MAX_OVER_TEMP_ON_DEFAULT);
    let offTemp = getNumberStateOrDefault(DP_PUMP_SAFETY_OFF_TEMP, MAX_OVER_TEMP_OFF_DEFAULT);

    // Hysterese erzwingen: Freigabe muss unter der Abschalttemperatur liegen.
    if (offTemp >= onTemp) offTemp = onTemp - 1;

    return { onTemp, offTemp };
}

function getWwTargetTemp() {
    const target = Number(getState(DP_WW_TARGET)?.val);
    return isNaN(target) ? null : target;
}

function isHeizstabRunning() {
    const aktiv = getState(DP_HEIZSTAB_AKTIV)?.val === true;
    const istLeistung = Number(getState(DP_HEIZSTAB_IST_LEISTUNG)?.val);

    if (!isNaN(istLeistung)) {
        return aktiv && istLeistung >= HEIZSTAB_RUNNING_MIN_W;
    }

    return aktiv;
}

function updateSollIst(reason = '') {
    const bypass = isBypassActive();
    const ist = readPumpIst();

    // Ist-Zustand immer publizieren
    setState(DP_PUMP_IST, ist, true);

    // Solange Überbrückung aktiv ist, keine Soll/Ist-Abweichung werten
    if (bypass) {
        setState(DP_PUMP_SOLL_IST_FEHLER, false, true);
        return;
    }

    // Nur prüfen, wenn wir schon mindestens einmal einen Soll-Zustand gesetzt haben
    if (pumpIsOn === null) {
        setState(DP_PUMP_SOLL_IST_FEHLER, false, true);
        return;
    }

    const mismatch = (ist !== pumpIsOn);
    setState(DP_PUMP_SOLL_IST_FEHLER, mismatch, true);

    if (mismatch) {
        const r = reason ? ` (${reason})` : '';
        log(`[Pumpe] Soll/Ist-Abweichung${r}: SOLL=${pumpIsOn ? 'EIN' : 'AUS'} / IST=${ist ? 'EIN' : 'AUS'} (DP=${DP_SHELLY_IST}, invert=${IST_INVERT})`, 'error');
    }
}

// =======================
// Logik
// =======================
function evaluate() {
    // Absolute Sicherheitsabschaltung mit Hysterese (auch bei Manual ON).
    // Fail-safe: Wenn der WW-Fühler nicht plausibel lesbar ist, bleibt die Pumpe AUS,
    // statt mit einem alten EIN-Zustand weiterzulaufen.
    const wwSafety = readTemperature(DP_WW_ACTUAL);
    if (!isValidWwTemperature(wwSafety.value)) {
        overTempActive = true;
        setSafetyActive(true);
        setPump(false);
        return;
    }

    const safetyTemps = getSafetyTemperatures();

    if (!overTempActive && wwSafety.value >= safetyTemps.onTemp) {
        overTempActive = true;
    } else if (overTempActive && wwSafety.value <= safetyTemps.offTemp) {
        overTempActive = false;
    }

    if (overTempActive) {
        setSafetyActive(true);
        setPump(false);
        return;
    }

    setSafetyActive(false);

    // Schlüssel-Überbrückung: Pumpe wird extern (Kessel) angesteuert.
    // Skript setzt dann seinen Soll-Zustand auf AUS (GPIO sicher) und bewertet keine Soll/Ist-Abweichung.
    if (isBypassActive()) {
        setPump(false, 'Bypass aktiv – GPIO sicher AUS');
        updateSollIst('bypass');
        return;
    }

    const manualMode = String(getState(DP_PUMP_MANUAL_MODE)?.val ?? 'AUTO').toUpperCase();

    // Manueller Modus hat Vorrang vor Automatik
    if (manualMode === 'ON') {
        setPump(true, 'ManualMode ON');
        return;
    }
    if (manualMode === 'OFF') {
        setPump(false, 'ManualMode OFF');
        return;
    }
    // manualMode === 'AUTO' -> weiter mit Automatik

    // Sicherheits-/Störfall: Shelly länger offline -> Fehler setzen und (nur im AUTO) Pumpe erzwingen AUS
    if (shellyOfflineFaultActive) {
        setState(DP_PUMP_ERROR, true, true);
        setPump(false, 'Shelly länger offline – AUTO sicher AUS');
        return;
    }

    const mode = getMode();

    if (mode === 'Kesselbetrieb') {
        // Im Kesselbetrieb wie im Unterstützungsbetrieb: externe Freigabe vom Kessel/Logik durchreichen
        setPump(!!getState(DP_SHELLY_INPUT)?.val, 'Externe Kessel-/Logikfreigabe');
        return;
    }

    if (mode === 'Unterstützungsbetrieb') {
        setPump(!!getState(DP_SHELLY_INPUT)?.val, 'Externe Kessel-/Logikfreigabe');
        return;
    }

    if (mode === 'Heizstabbetrieb') {
        const tWw = wwSafety.value;
        const tPuffer = Number(getState(DP_PUFFER_TEMP)?.val);
        if (isNaN(tPuffer)) {
            setPump(false);
            return;
        }

        const zielTemp = getWwTargetTemp();
        const heizstabRunning = isHeizstabRunning();

        // Fallback auf alte Hysterese, falls die WW-Zieltemperatur nicht lesbar ist.
        if (zielTemp === null) {
            if (tWw > OFF_ABOVE_TEMP) {
                setPump(false, 'Fallback-Hysterese: WW über Ausschaltgrenze');
                return;
            }

            if (tWw < ON_BELOW_TEMP) {
                setPump(tPuffer > tWw, 'Fallback-Hysterese: Puffer wärmer als WW');
                return;
            }

            return;
        }

        // Zieltemperatur im Warmwasserspeicher erreicht: Ladepumpe aus.
        if (tWw >= zielTemp) {
            setPump(false, 'WW-Zieltemperatur erreicht');
            return;
        }

        // Heizstab aus und Puffer noch unter Ziel: Zieltemperatur kann nicht erreicht werden, daher keine Speicherladung.
        if (!heizstabRunning && tPuffer < zielTemp) {
            setPump(false, 'Heizstab aus und Puffer unter Zieltemperatur');
            return;
        }

        // Solange die Zieltemperatur noch nicht erreicht ist und sie erreichbar bleibt, Speicherladepumpe laufen lassen.
        // Das gilt auch, wenn der Heizstab läuft und der Puffer selbst noch unter der Zieltemperatur liegt.
        setPump(true, 'Heizstabbetrieb: WW-Ziel noch nicht erreicht');
        return;
    }

    setPump(false, 'Unbekannter Betriebsmodus – Pumpe AUS');
    updateSollIst('evaluate');
}

// =======================
// Trigger
// =======================
on({ id: DP_MODE, change: 'ne' }, evaluate);

on({ id: DP_SHELLY_INPUT, change: 'ne' }, () => {
    if (shellyTimer) clearTimeout(shellyTimer);
    shellyTimer = setTimeout(evaluate, DEBOUNCE_SHELLY_MS);
});

on({ id: DP_SHELLY_IST, change: 'ne' }, () => {
    if (istTimer) clearTimeout(istTimer);
    istTimer = setTimeout(() => updateSollIst('istChange'), DEBOUNCE_IST_MS);
});

on({ id: DP_SHELLY_ONLINE, change: 'ne' }, obj => {
    const online = !!obj.state.val;

    if (online) {
        // wieder online: Fehler zurücksetzen und Timer stoppen
        if (shellyOfflineTimer) clearTimeout(shellyOfflineTimer);
        shellyOfflineTimer = null;
        shellyOfflineFaultActive = false;
        setState(DP_PUMP_ERROR, false, true);
        evaluate();
        return;
    }

    // offline: erst nach Timeout als Fehler werten
    if (shellyOfflineTimer) clearTimeout(shellyOfflineTimer);
    shellyOfflineTimer = setTimeout(() => {
        // nur aktivieren, wenn immer noch offline
        const curOnline = !!getState(DP_SHELLY_ONLINE)?.val;
        if (!curOnline) {
            shellyOfflineFaultActive = true;
            setState(DP_PUMP_ERROR, true, true);
            evaluate(); // bewertet unter Berücksichtigung von ManualMode
        }
    }, SHELLY_OFFLINE_TIMEOUT_MS);
});

function scheduleTempEvaluate() {
    if (tempTimer) clearTimeout(tempTimer);
    tempTimer = setTimeout(evaluate, DEBOUNCE_TEMP_MS);
}

// WW-Sicherheitsgrenze ohne zusätzliche 10s-Verzögerung bewerten.
on({ id: DP_WW_ACTUAL, change: 'ne' }, evaluate);
on({ id: DP_PUFFER_TEMP, change: 'ne' }, scheduleTempEvaluate);
on({ id: DP_WW_TARGET, change: 'ne' }, scheduleTempEvaluate);
on({ id: DP_PUMP_SAFETY_ON_TEMP, change: 'ne' }, evaluate);
on({ id: DP_PUMP_SAFETY_OFF_TEMP, change: 'ne' }, evaluate);
on({ id: DP_HEIZSTAB_AKTIV, change: 'ne' }, evaluate);
on({ id: DP_HEIZSTAB_IST_LEISTUNG, change: 'ne' }, scheduleTempEvaluate);

on({ id: DP_PUMP_MANUAL_MODE, change: 'ne' }, () => {
    evaluate();
});

on({ id: DP_PUMP_BYPASS, change: 'ne' }, () => {
    evaluate();
});

// =======================
// GPIO-Test bei Start
// =======================
function toggleGPIO(dp, cb) {
    const orig = !!getState(dp)?.val;
    setState(dp, !orig, true);
    setTimeout(() => {
        setState(dp, orig, true);
        cb && cb();
    }, GPIO_TEST_DELAY_MS);
}

function startupGpioTest() {
    toggleGPIO(DP_GPIO17, () => {
        toggleGPIO(DP_GPIO18, () => {
            evaluate();
        });
    });
}

// =======================
// Init
// =======================
(function () {
    // Userdata-States anlegen (falls noch nicht vorhanden), sonst gibt es Warnungen "state not found"
    createState(DP_PUMP_STATE, false, {
        name: 'Speicherladepumpe Status',
        type: 'boolean',
        role: 'indicator',
        read: true,
        write: false
    });

    createState(DP_PUMP_ERROR, false, {
        name: 'Speicherladepumpe Fehler: Shelly offline >10s',
        type: 'boolean',
        role: 'indicator',
        read: true,
        write: false
    });

    createState(DP_PUMP_IST, false, {
        name: 'Speicherladepumpe Ist-Zustand (Schütz)',
        type: 'boolean',
        role: 'indicator',
        read: true,
        write: false
    });

    createState(DP_PUMP_SOLL_IST_FEHLER, false, {
        name: 'Speicherladepumpe Soll/Ist-Abweichung',
        type: 'boolean',
        role: 'indicator',
        read: true,
        write: false
    });

    createState(DP_PUMP_SAFETY_ACTIVE, false, {
        name: 'Speicherladepumpe Sicherheitsabschaltung aktiv',
        type: 'boolean',
        role: 'indicator',
        read: true,
        write: false
    });

    createState(DP_PUMP_SAFETY_ON_TEMP, MAX_OVER_TEMP_ON_DEFAULT, {
        name: 'Speicherladepumpe Sicherheitsabschaltung EIN ab WW-Temperatur',
        type: 'number',
        role: 'value.temperature',
        unit: '°C',
        min: 30,
        max: 90,
        read: true,
        write: true
    });

    createState(DP_PUMP_SAFETY_OFF_TEMP, MAX_OVER_TEMP_OFF_DEFAULT, {
        name: 'Speicherladepumpe Sicherheitsabschaltung AUS/Freigabe ab WW-Temperatur',
        type: 'number',
        role: 'value.temperature',
        unit: '°C',
        min: 20,
        max: 89,
        read: true,
        write: true
    });

    createState(DP_PUMP_BYPASS, false, {
        name: 'Speicherladepumpe Überbrückung (Schlüsselschalter)',
        type: 'boolean',
        role: 'switch',
        read: true,
        write: true
    });

    createState(DP_PUMP_MANUAL_MODE, 'AUTO', {
        name: 'Speicherladepumpe Manuell',
        type: 'string',
        role: 'value',
        read: true,
        write: true,
        states: {
            AUTO: 'Auto',
            ON:   'Ein',
            OFF:  'Aus'
        }
    });

    // Initialwerte setzen
    setState(DP_PUMP_STATE, false, true);
    setState(DP_PUMP_MANUAL_MODE, 'AUTO', true);
    setState(DP_PUMP_ERROR, false, true);
    setState(DP_PUMP_IST, readPumpIst(), true);
    setState(DP_PUMP_SOLL_IST_FEHLER, false, true);
    // DP_PUMP_SAFETY_ACTIVE nicht direkt nach createState setzen:
    // ioBroker legt neue States asynchron an und würde beim ersten Start sonst "state not found" warnen.
    // Der Initialwert kommt aus createState; spätere evaluate()-Aufrufe aktualisieren ihn.
    // DP_PUMP_BYPASS bewusst nicht überschreiben (physischer Schalter)

    // Startzustand Shelly online prüfen (falls beim Start schon offline)
    const startOnline = !!getState(DP_SHELLY_ONLINE)?.val;
    shellyOfflineFaultActive = false;
    if (!startOnline) {
        // Timer starten wie im Trigger
        if (shellyOfflineTimer) clearTimeout(shellyOfflineTimer);
        shellyOfflineTimer = setTimeout(() => {
            const curOnline = !!getState(DP_SHELLY_ONLINE)?.val;
            if (!curOnline) {
                shellyOfflineFaultActive = true;
                setState(DP_PUMP_ERROR, true, true);
                evaluate(); // bewertet unter Berücksichtigung von ManualMode
            }
        }, SHELLY_OFFLINE_TIMEOUT_MS);
    }

    updateSollIst('init');

    startupGpioTest();
})();
