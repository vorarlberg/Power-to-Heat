function clamp(v, min, max) { return Math.min(max, Math.max(min, v)); }
function wait(ms) { return new Promise(res => setTimeout(res, ms)); }

function isOfflineCheckDisabledNow() {
    const h = new Date().getHours();
    // Fenster über Mitternacht: z.B. 22..4
    if (QUIET.offlineCheckOffFromHour > QUIET.offlineCheckOffToHour) {
        return (h >= QUIET.offlineCheckOffFromHour) || (h < QUIET.offlineCheckOffToHour);
    }
    // normales Fenster ohne Mitternacht
    return (h >= QUIET.offlineCheckOffFromHour) && (h < QUIET.offlineCheckOffToHour);
}

// Quittierungspflichtige Fehlercodes und Status
const ACK_CODES = new Set(['TP004', 'ABW001', 'PWM400', 'PWMERR', 'FI001']);
const ACK_STATUS = {
    NICHT_QUITTIERBAR: 'NICHT_QUITTIERBAR',
    QUITTIERBAR: 'QUITTIERBAR',
    QUITTIERT: 'QUITTIERT'
};

function _extractAckCode(msg) {
    const m = String(msg ?? '').match(/\[(TP004|ABW001|PWM400|PWMERR|FI001|BP001)\]/);
    return m ? m[1] : null;
}

function _readTempsAndLimits() {
    const tInt = Number(getState(EXTERNAL.tempInternC)?.val) || 0;
    const tExt = Number(getState(EXTERNAL.tempExternC)?.val) || 0;
    const gInt = Number(getState(DP.uebertempIntern)?.val) || LIMITS.uebertempInternDefault;
    const gExt = Number(getState(DP.uebertempExtern)?.val) || LIMITS.uebertempExternDefault;
    return { tInt, tExt, gInt, gExt };
}

function _currentAckStatusFor(code) {
    if (!code) return null;
    if (code === 'ABW001') return ACK_STATUS.QUITTIERBAR;
    if (code === 'TP004') {
        const { tInt, tExt, gInt, gExt } = _readTempsAndLimits();
        const over = (tInt >= gInt) || (tExt >= gExt);
        return over ? ACK_STATUS.NICHT_QUITTIERBAR : ACK_STATUS.QUITTIERBAR;
    }
    if (code === 'FI001') {
    const fi = (getState(EXTERNAL.fiHeizstabOK)?.val === true);
    return fi ? ACK_STATUS.QUITTIERBAR : ACK_STATUS.NICHT_QUITTIERBAR;
}
    if (code === 'PWM400' || code === 'PWMERR') {
        return _pwmFaultActive ? ACK_STATUS.NICHT_QUITTIERBAR : ACK_STATUS.QUITTIERT;
    }
    if (code === 'BP001') {
        // Bypass-Status der Speicherladepumpe (informativ, nicht quittierpflichtig)
        const bypassOn = (getState('shelly.1.shellyprorgbwwpm#ece334f93c48#1.RGB0.Switch')?.val === true);
        return bypassOn ? 'AKTIV' : 'INAKTIV';
    }
    return null;
}

let _pendingLogEntries = [];

function _readLogArray() {
    const curr = String(getState(DP.log)?.val ?? '[]').trim();
    if (!curr) return [];
    try {
        const parsed = JSON.parse(curr);
        return Array.isArray(parsed) ? parsed : [];
    } catch {
        return [];
    }
}

function _writeLogArray(arr) {
    const limited = (Array.isArray(arr) ? arr : []).slice(0, 200);
    setState(DP.log, JSON.stringify(limited), true);
}

function _flushPendingLog() {
    if (!existsObject(DP.log)) return;
    if (_pendingLogEntries.length === 0) return;

    const existing = _readLogArray();
    const combined = [..._pendingLogEntries, ...existing].slice(0, 200);
    _writeLogArray(combined);
    _pendingLogEntries = [];
}

function updateLogAckStatus(code, status) {
    if (!code || !status) return;
    if (!existsObject(DP.log)) return;

    const arr = _readLogArray();
    for (let i = 0; i < arr.length; i++) {
        const e = arr[i] || {};
        if (e.FehlerCode === code) {
            arr[i] = {
    ...e,
    Zeitstempel: String(e.Zeitstempel ?? ''),
    Meldung: String(e.Meldung ?? ''),
    FehlerCode: String(code ?? ''),
    FehlerStatus: String(status ?? '')
};
            _writeLogArray(arr);
            return;
        }
    }
}

function appendLog(message) {
    const d = new Date();
const ts =
    d.getFullYear() + '-' +
    String(d.getMonth() + 1).padStart(2, '0') + '-' +
    String(d.getDate()).padStart(2, '0') + ' ' +
    String(d.getHours()).padStart(2, '0') + ':' +
    String(d.getMinutes()).padStart(2, '0') + ':' +
    String(d.getSeconds()).padStart(2, '0');

    let msgOneLine = String(message ?? '')
        .replace(/[\r\n]+/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();

    const ackCode = _extractAckCode(msgOneLine);

    // Token entfernen -> Fehlercode steht nur in FehlerCode
    if (ackCode) {
        const token = `[${ackCode}]`;
        msgOneLine = msgOneLine.replace(token, '').replace(/\s+/g, ' ').trim();
    }

    const entry = {
        Zeitstempel: ts,
        Meldung: msgOneLine,
        FehlerCode: ackCode ? String(ackCode) : '',
        FehlerStatus: ackCode ? String(_currentAckStatusFor(ackCode) ?? '') : ''
    };

    if (!existsObject(DP.log)) {
        _pendingLogEntries = [entry, ..._pendingLogEntries].slice(0, 200);
        return;
    }

    const arr = _readLogArray();
    const next = [entry, ...arr].slice(0, 200);
    _writeLogArray(next);
}

function calcPlausibilityDelay(targetWatt) {
    const curr = Number(getState(DP.pwmWatt)?.val) || 0;
    const diff = Math.abs(targetWatt - curr);
    const rampMs = (diff / RAMP.rateWps) * 1000;
    return rampMs + TIMES.plausiCheckMs;
}

function prozentAbweichung(soll, ist) {
    if (soll === 0) return 0;
    return Math.abs(((ist - soll) / soll) * 100);
}

// MQTT LWT interpretieren
function _isLWTOnline(val) {
    const s = String(val ?? '').trim().toLowerCase();
    return s === 'online' || s === 'on' || s === 'true' || s === '1';
}

// Prüft alle relevanten Geräte auf "offline" und gibt Liste zurück
function getOfflineDevices() {
    const offline = [];

    const lwtRechts = getState(EXTERNAL.zaehlerRechtsLWT)?.val;
    const lwtLinks  = getState(EXTERNAL.zaehlerLinksLWT)?.val;
    if (!_isLWTOnline(lwtRechts)) offline.push('Zähler rechts');
    if (!_isLWTOnline(lwtLinks))  offline.push('Zähler links');

    const wrDach = getState(EXTERNAL.wrDachOnline)?.val === true;
    const wrFas  = getState(EXTERNAL.wrFassadeOnline)?.val === true;
    if (!wrDach) offline.push('Wechselrichter Dach');
    if (!wrFas)  offline.push('Wechselrichter Fassade');

    return offline;
}

function _offlineKey(list) {
    return (Array.isArray(list) ? list : []).slice().sort().join('|');
}

// ABW-Persistenzprüfung: Abweichung muss über eine Dauer konstant > Schwelle bleiben
async function abweichungPersistiert(sollW, tokenRef) {
    const start = Date.now();
    while (Date.now() - start < ABW.persistMs) {
        if (tokenRef !== _targetToken) return false;

        const istW = Number(getState(EXTERNAL.istLeistungW)?.val) || 0;
        const abw = prozentAbweichung(sollW, istW);

        if (abw <= ABW.toleranzProzent) return false;

        await wait(ABW.sampleMs);
    }
    return true;
}

// Kalibrierung: Watt (Soll) → PWM-Watt (aus Kennlinie)
function kalibrierteLeistung(sollWatt) {
    const json = (getState(DP.kalDaten)?.val || '{}');
    let daten;
    try { daten = JSON.parse(json); } catch (e) { daten = {}; }
    const keys = Object.keys(daten).map(k => parseInt(k, 10)).sort((a, b) => a - b);
    if (!keys.length) return Math.round(sollWatt);

    for (let i = 0; i < keys.length - 1; i++) {
        const x0 = keys[i], x1 = keys[i + 1];
        const y0 = Number(daten[x0]), y1 = Number(daten[x1]);
        if (sollWatt >= y0 && sollWatt <= y1 && (y1 - y0) !== 0) {
            const pwm = x0 + ((sollWatt - y0) * (x1 - x0)) / (y1 - y0);
            return Math.round(pwm);
        }
    }
    return Math.round(sollWatt);
}

// Event-Trigger
let _eventTimer = null;
function requestRegelzyklusByEvent(reason) {
    const now = Date.now();
    if (now - _lastEventRegelTs < EVENT.debounceMs) return;

    const einspeisungW = Number(getState(EXTERNAL.ueberschussW)?.val) || 0;
    const netzverbrauchW = Number(getState(EXTERNAL.netzverbrauchW)?.val) || 0;
    const netzNettoW = einspeisungW - netzverbrauchW;

    if (_lastNetzNettoW !== null && Math.abs(netzNettoW - _lastNetzNettoW) < EVENT.deltaWTrigger) return;
    _lastNetzNettoW = netzNettoW;

    _lastEventRegelTs = now;

    if (_eventTimer) clearTimeout(_eventTimer);
    _eventTimer = setTimeout(() => {
        log(`[Regelung] Event-Trigger (${reason}): netzNetto=${netzNettoW}W`, 'info');
        regelzyklus();
    }, 0);
}


