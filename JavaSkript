/* ==========================================================
   8) HAUPTREGELUNG
   ========================================================== */

let _wwRunning = false; // Hysterese-Flag für WW-Sicherstellung
let _nextRunTs = Date.now() + (TIMES.regelIntervallSek * 1000);
let _lastEventRegelTs = 0;
let _lastNetzNettoW = null;

let _sperreAktiv = false;
let _pvRunning = false;

let _regelzyklusRunning = false;
let _targetToken = 0;
let _ackRequested = false;

let _connFault = false;
let _offlineSinceTs = null;
let _offlineLastList = '';

let _pwmFaultActive = false;
let _maxTempLatched = false; // Max-Temp erreicht -> erst wieder freigeben wenn Temp unter (Max - DeltaT) fällt
let _maxTempMsgSent = false; // verhindert wiederholte TP002-Statusmeldungen während der Sperre

let _fiOffSinceTs = null;
let _fiFaultLatched = false; // FI-Fehler wurde ausgelöst und wartet auf Quittierung

async function regelzyklus() {
    if (_regelzyklusRunning) return;
    _regelzyklusRunning = true;

    _nextRunTs = Date.now() + (TIMES.regelIntervallSek * 1000);
    setState(DP.nextRunInSek, TIMES.regelIntervallSek, true);

    // Betriebsmodus: Kesselbetrieb blockiert Heizstab-Regelung
    const modeNow = String(getState(DP.betriebsmodus)?.val || 'Heizstabbetrieb').trim();
    if (modeNow === 'Kesselbetrieb') {
        setPWM_TargetWatt(0);
        setState(DP.sollWattRaw, 0, true);
        setState(DP.aktiv, false, true);
        // ENABLE sicher ausschalten
        if (getState(DP.regelungEnable)?.val === true) {
            setState(DP.regelungEnable, false, true);
        }
        // Status nicht bei jedem Zyklus neu überschreiben, nur wenn abweichend
        const st = String(getState(DP.status)?.val || '');
        if (!st.includes('Kesselbetrieb')) {
            setState(DP.status, 'Betriebsmodus: Kesselbetrieb – Heizstab deaktiviert. [MODE001]', true);
        }
        updateAmpel();
        _regelzyklusRunning = false;
        return;
    }
// FI/LS-Überwachung (harte Abschaltung, quittierpflichtig)
const fiOK = (getState(EXTERNAL.fiHeizstabOK)?.val === true);

if (!fiOK) {
    // Entprellen: muss FI.persistMs am Stück AUS sein
    if (_fiOffSinceTs === null) _fiOffSinceTs = Date.now();
    const elapsed = Date.now() - _fiOffSinceTs;

    if (elapsed >= FI.persistMs) {
        _fiFaultLatched = true;
        setFaultActive('FI001', ACK_STATUS.NICHT_QUITTIERBAR);

        setPWM_Immediate(0);
        setState(DP.sollWattRaw, 0, true);
        setState(DP.aktiv, false, true);
        _sperreAktiv = true;

        const msg = 'FI/LS ist AUS – Heizstab abgeschaltet. [FI001]';
        const st = String(getState(DP.status)?.val || '');
        if (!st.includes('[FI001]')) {
            setState(DP.status, msg, true);
            appendLog(msg);
        }

        updateAmpel();
        updateAckBlink();
        _regelzyklusRunning = false;
        return;
    } else {
        const waitSec = Math.ceil((FI.persistMs - elapsed) / 1000);
        setState(DP.status, `FI/LS AUS erkannt – warte ${waitSec}s. [FI010]`, true);
        _regelzyklusRunning = false;
        return;
    }
} else {
    _fiOffSinceTs = null;

    // Wenn FI-Fehler zuvor ausgelöst wurde: jetzt quittierbar (bis Reset)
    if (_fiFaultLatched) {
        setFaultActive('FI001', ACK_STATUS.QUITTIERBAR);
        updateAckBlink();
    }
}

    try {
        // Online-Checks (nachts aus)
        if (isOfflineCheckDisabledNow()) {
            if (_connFault || _offlineSinceTs !== null) {
                _connFault = false;
                _offlineSinceTs = null;
                _offlineLastList = '';
                setState(DP.status, 'Nachtmodus: Online-Checks pausiert (22–04). Regelung freigegeben. [OFF090]', true);
                appendLog('OFF090: Nachtmodus – Online-Checks pausiert (22–04), Regelung freigegeben');
            }
        } else {
            const offline = getOfflineDevices();
            if (offline.length > 0) {
                const key = _offlineKey(offline);

                if (_offlineSinceTs === null || _offlineLastList !== key) {
                    _offlineSinceTs = Date.now();
                    _offlineLastList = key;
                    setState(DP.status, `Gerät offline (warte ${Math.round(OFFLINE.persistMs/1000)}s): ${offline.join(', ')}. [OFF010]`, true);
                    appendLog(`OFF010: Offline erkannt – Wartezeit startet: ${offline.join(', ')}`);
                    return;
                }

                const elapsed = Date.now() - _offlineSinceTs;
                if (elapsed < OFFLINE.persistMs) {
                    setState(DP.status, `Gerät offline (warte ${Math.ceil((OFFLINE.persistMs - elapsed)/1000)}s): ${offline.join(', ')}. [OFF010]`, true);
                    return;
                }

                _connFault = true;
                setPWM_Immediate(0);
                setState(DP.sollWattRaw, 0, true);
                setState(DP.aktiv, false, true);
                setState(DP.status, `Gerät offline: ${offline.join(', ')}. Heizstab aus. [OFF001]`, true);
                appendLog(`OFF001: Abschaltung wegen Offline: ${offline.join(', ')}`);
                return;
            } else {
                _offlineSinceTs = null;
                _offlineLastList = '';
            }

            if (_connFault) {
                _connFault = false;
                setState(DP.status, 'Alle Geräte wieder online. Regelung freigegeben. [OFF000]', true);
                appendLog('OFF000: Alle Geräte wieder online – Regelung freigegeben');
            }
        }

        // Übertemperatur hart prüfen
        const tInt = Number(getState(EXTERNAL.tempInternC)?.val) || 0;
        const tExt = Number(getState(EXTERNAL.tempExternC)?.val) || 0;
        const gInt = Number(getState(DP.uebertempIntern)?.val) || LIMITS.uebertempInternDefault;
        const gExt = Number(getState(DP.uebertempExtern)?.val) || LIMITS.uebertempExternDefault;

        if (tInt >= gInt || tExt >= gExt) {
            const triggers = [];
            if (tInt >= gInt) triggers.push(`intern ${tInt.toFixed(1)}°C ≥ ${gInt.toFixed(1)}°C`);
            if (tExt >= gExt) triggers.push(`extern ${tExt.toFixed(1)}°C ≥ ${gExt.toFixed(1)}°C`);
            const trigText = triggers.length ? triggers.join(' | ') : `intern ${tInt.toFixed(1)}°C / extern ${tExt.toFixed(1)}°C`;

            const msg = `Übertemperatur erkannt (${trigText}) – Abschaltung. [TP004]`;
            setState(DP.status, msg, true);

            setFaultActive('TP004', ACK_STATUS.NICHT_QUITTIERBAR);

            setPWM_Immediate(0);
            setState(DP.sollWattRaw, 0, true);
            setState(DP.aktiv, false, true);

            _sperreAktiv = true;
            updateAckBlink();
            return;
        }

        // Sperre quittieren?
        if (_sperreAktiv) {
            refreshDynamicFaultStatuses();
            updateAckBlink();

            if (_ackRequested) {
                _ackRequested = false;

                refreshDynamicFaultStatuses();
                if (hasNonQuittierbarFault() || !hasQuittierbarFault()) {
                    setState(DP.status, 'Quittierung nicht möglich – kein quittierbarer Fehler vorhanden oder nicht quittierbar.', true);
                    updateAckBlink();
                    return;
                }

                // alle quittierbaren Fehler löschen
                for (const [code, v] of Array.from(_activeFaults.entries())) {
                    if (v?.status === ACK_STATUS.QUITTIERBAR) {
                        clearFault(code);
                    }
                }
                
                // FI-Latch zurücksetzen, wenn FI001 quittiert wurde
if (!_activeFaults.has('FI001')) {
    _fiFaultLatched = false;
}

                // Sperre nur aufheben, wenn keine aktiven Fehler mehr vorhanden sind
                if (_activeFaults.size === 0) {
                    _sperreAktiv = false;
                    log('[Heizstab] Sperre aufgehoben durch Quittierung.', 'info');
                }
                updateAckBlink();
            } else {
                return;
            }
        }

        // Sperre wegen Kalibrierung/Selbsttest?
        if (getState(DP.sperreRegelung)?.val === true) {
            const kal = getState(DP.kalRunning)?.val === true;
            setState(DP.status, kal ? 'Regelung pausiert (Kalibrierung aktiv).' : 'Regelung gesperrt.', true);
            setState(DP.aktiv, false, true);
            if (!kal) {
                setPWM_TargetWatt(0);
                setState(DP.sollWattRaw, 0, true);
            }
            return;
        }

        // Manuelle Freigabe?
        if (getState(DP.regelungEnable)?.val !== true) {
            setState(DP.status, 'Regelung manuell deaktiviert. [RG001]', true);
            setState(DP.aktiv, false, true);
            setPWM_TargetWatt(0);
            setState(DP.sollWattRaw, 0, true);
            return;
        }

        // Sensor-/Parameter-Werte
        const einspeisungW = Number(getState(EXTERNAL.ueberschussW)?.val) || 0;
        const netzverbrauchW = Number(getState(EXTERNAL.netzverbrauchW)?.val) || 0;
        const istHeiz = Number(getState(EXTERNAL.istLeistungW)?.val) || 0;

        const netzNettoW = einspeisungW - netzverbrauchW;

        // verfügbarer Überschuss (stabiler): Netto + aktuelle Heizleistung
        const ueberschuss = netzNettoW + istHeiz;

        const tempExt = Number(getState(EXTERNAL.tempExternC)?.val) || 0;
        const speicherTemp = Number(getState(EXTERNAL.speicherTempC)?.val) || 0;
        const tempMin = Number(getState(DP.tempMin)?.val) || LIMITS.wwTempMinDefault;
        const tempMax = Number(getState(DP.tempMax)?.val) || LIMITS.wwTempMaxDefault;
        const deltaT = Number(getState(DP.deltaT)?.val) || PARAM.deltaTRegelbereich_Default;
        const zielTemp = Number(getState(DP.wwZiel)?.val) || PARAM.wwZieltemp_Default;
        const wwAktiv = getState(DP.wwSicherAn)?.val === true;

        // Max-Temp (gilt immer) – mit Hysterese über DeltaT_Regelbereich
        // Wenn einmal >= tempMax erreicht: erst wieder freigeben, wenn tempExt <= (tempMax - deltaT)
        const maxTempRelease = tempMax - Math.max(0, deltaT);

        if (!_maxTempLatched && tempExt >= tempMax) {
            _maxTempLatched = true;
            _maxTempMsgSent = false; // neuer Sperrzyklus
        }

        if (_maxTempLatched) {
            // Freigabe erst unterhalb der Hysterese
            if (tempExt <= maxTempRelease) {
                _maxTempLatched = false;
                _maxTempMsgSent = false;
                appendLog(`TP002: Max-Temp-Hysterese freigegeben – Temperatur ${tempExt}°C <= ${maxTempRelease.toFixed(1)}°C`);
            } else {
                if (!_maxTempMsgSent) {
                    setState(
                        DP.status,
                        `Maximaltemperatur erreicht – Warte bis <= ${maxTempRelease.toFixed(1)}°C (aktuell ${tempExt}°C). [TP002]`,
                        true
                    );
                    _maxTempMsgSent = true;
                }
                setPWM_TargetWatt(0);
                setState(DP.sollWattRaw, 0, true);
                setState(DP.aktiv, false, true);
                return;
            }
        }

        // WW-Sicherstellung (Hysterese)
        if (wwAktiv) {
            // AUS: Ziel erreicht
            if (_wwRunning && speicherTemp >= zielTemp) {
                setPWM_TargetWatt(0);
                setState(DP.sollWattRaw, 0, true);
                setState(DP.aktiv, false, true);
                setState(DP.status, `WW Zieltemperatur ${zielTemp}°C erreicht – Heizstab aus. [TP003]`, true);
                _wwRunning = false;
                return;
            }

            // Wenn läuft und Ziel noch nicht erreicht: weiter heizen
            if (_wwRunning && speicherTemp < zielTemp) {
                const sollWattRaw = WW_SICHER.leistungW;
                setState(DP.sollWattRaw, sollWattRaw, true);
                const leistung = kalibrierteLeistung(sollWattRaw);
                setPWM_TargetWatt(leistung);
                setState(DP.aktiv, true, true);
                setState(DP.status, 'WW Sicherstellung aktiv. [TP003]', true);
                return;
            }

            // EIN: <= Ziel-DeltaT oder <= MinTemp
            const wwOn = (!_wwRunning) && (speicherTemp <= (zielTemp - deltaT) || speicherTemp <= tempMin);
            if (wwOn) {
                const sollWattRaw = WW_SICHER.leistungW;
                setState(DP.sollWattRaw, sollWattRaw, true);
                const leistung = kalibrierteLeistung(sollWattRaw);

                setPWM_TargetWatt(leistung);
                setState(DP.aktiv, true, true);
                setState(DP.status, 'WW Sicherstellung aktiv. [TP003]', true);
                _wwRunning = true;

                const tokenWW = _targetToken;
                await wait(calcPlausibilityDelay(leistung));
                if (tokenWW !== _targetToken) return;

                const sollWW = Number(getState(DP.pwmWatt)?.val) || 0;
                if (sollWW > 0) {
                    const abwPersist = await abweichungPersistiert(sollWW, tokenWW);
                    if (abwPersist) {
                        setState(DP.status, 'Abweichung erkannt. Heizstab gesperrt. [ABW001]', true);
                        appendLog(`Abweichung > Toleranz – Heizstab gesperrt. [ABW001]`);

                        setFaultActive('ABW001', ACK_STATUS.QUITTIERBAR);

                        const istWW = Number(getState(EXTERNAL.istLeistungW)?.val) || 0;
                        const abwWW = prozentAbweichung(sollWW, istWW);
                        log(`[Heizstab] Abweichung >${ABW.toleranzProzent}% (>=${ABW.persistMs}ms): Soll=${sollWW}W Ist=${istWW}W Abw=${abwWW.toFixed(1)}%`, 'warn');

                        setPWM_Immediate(0);
                        setState(DP.sollWattRaw, 0, true);
                        setState(DP.aktiv, false, true);
                        _sperreAktiv = true;
                        _wwRunning = false;
                        updateAckBlink();
                    }
                }
                return;
            }

            // innerhalb Hysterese: aus
            setPWM_TargetWatt(0);
            setState(DP.sollWattRaw, 0, true);
            setState(DP.aktiv, false, true);
            setState(DP.status, `WW Sicherstellung: Warte (EIN bei ≤ ${(zielTemp - deltaT).toFixed(1)}°C). [TP003]`, true);
            return;
        }

        // PV-Überschussbetrieb
        const pvOnSchwelle = 500 + LIMITS.hystereseW;
        const pvOffSchwelle = 500 - LIMITS.hystereseW;

        const pvOK = _pvRunning ? (ueberschuss > pvOffSchwelle) : (ueberschuss > pvOnSchwelle);

        if (pvOK) {
            let sollWattRaw = clamp(ueberschuss - LIMITS.hystereseW, 0, LIMITS.maxPowerW);
            setState(DP.sollWattRaw, Math.round(sollWattRaw), true);

            const pwm = kalibrierteLeistung(sollWattRaw);
            setPWM_TargetWatt(pwm);
            setState(DP.aktiv, true, true);
            setState(DP.status, 'Regelung aktiv. [RG003]', true);
            _pvRunning = true;

            const tokenPV = _targetToken;
            await wait(calcPlausibilityDelay(pwm));
            if (tokenPV !== _targetToken) return;

            const sollPV = Number(getState(DP.pwmWatt)?.val) || 0;
            if (sollPV > 0) {
                const abwPersist = await abweichungPersistiert(sollPV, tokenPV);
                if (abwPersist) {
                    setState(DP.status, 'Abweichung erkannt. Heizstab gesperrt. [ABW001]', true);
                    appendLog(`Abweichung > Toleranz – Heizstab gesperrt. [ABW001]`);

                    setFaultActive('ABW001', ACK_STATUS.QUITTIERBAR);

                    const istPV = Number(getState(EXTERNAL.istLeistungW)?.val) || 0;
                    const abwPV = prozentAbweichung(sollPV, istPV);
                    log(`[Heizstab] Abweichung >${ABW.toleranzProzent}% (>=${ABW.persistMs}ms): Soll=${sollPV}W Ist=${istPV}W Abw=${abwPV.toFixed(1)}%`, 'warn');

                    setPWM_Immediate(0);
                    setState(DP.sollWattRaw, 0, true);
                    setState(DP.aktiv, false, true);
                    _sperreAktiv = true;
                    updateAckBlink();
                }
            }
        } else {
            setPWM_TargetWatt(0);
            _pvRunning = false;
            setState(DP.sollWattRaw, 0, true);
            setState(DP.status, 'Überschuss zu gering. Heizstab aus. [RG004]', true);
            setState(DP.aktiv, false, true);
        }
    } finally {
        _regelzyklusRunning = false;
    }
}


/* ==========================================================
   4a) PWM-Status überwachen: Fehler ins JSON-Log + rote LED + Fault-Set
   ========================================================== */

on({ id: DP.pwmStatus, change: 'ne' }, (obj) => {
    const msg = String(obj.state?.val || '').trim();
    if (!msg) return;

    const isFault = msg.toLowerCase().includes('offline') || msg.toLowerCase().includes('fehler') || msg.includes('(400)');

    if (isFault) {
        const code = (msg.includes('(400)') || msg.toLowerCase().includes('offline')) ? 'PWM400' : 'PWMERR';

        if (!_pwmFaultActive) {
            _pwmFaultActive = true;
            appendLog(`PWM: ${msg} [${code}]`);
        }

        // in Fault-Set abbilden
        setFaultActive(code, ACK_STATUS.NICHT_QUITTIERBAR);

        updateAmpel();
        updateAckBlink();
        return;
    }

    // kein Fault mehr -> auto quittieren
    if (_pwmFaultActive) {
        _pwmFaultActive = false;

        clearFault('PWM400');
        clearFault('PWMERR');

        updateAmpel();
        updateAckBlink();
    }
});



function checkPumpScriptVersions() {
    const mismatches = [];

    for (const script of PUMP_SCRIPT_CHECK.scripts) {
        const st = getState(script.dp);
        const current = st && st.val !== null && st.val !== undefined ? String(st.val) : '';
        if (current !== script.expected) {
            mismatches.push(`${script.name}: erwartet ${script.expected}, ist ${current || 'nicht vorhanden'}`);
        }
    }

    if (mismatches.length > 0) {
        const msg = `Pumpenskripte nicht auf Soll-Stand: ${mismatches.join(' | ')}`;
        setState(DP.pumpScriptsOk, false, true);
        setState(DP.pumpScriptsError, msg, true);
        log(`[VERSION] ${msg}`, 'error');
        return false;
    }

    setState(DP.pumpScriptsOk, true, true);
    setState(DP.pumpScriptsError, '', true);
    return true;
}

/* ==========================================================
   8a) Trigger / Scheduler
   ========================================================== */

// Event-getriggerte Regelung bei Netzänderungen (mit Debounce)
on({ id: EXTERNAL.ueberschussW, change: 'ne' }, () => requestRegelzyklusByEvent('Netzeinspeisung'));
on({ id: EXTERNAL.netzverbrauchW, change: 'ne' }, () => requestRegelzyklusByEvent('Netzverbrauch'));
on({ id: EXTERNAL.fiHeizstabOK, change: 'ne' }, () => regelzyklus());

// Event-getriggerte Regelung bei Geräte-Online-Statusänderungen
on({ id: EXTERNAL.zaehlerRechtsLWT, change: 'ne' }, () => regelzyklus());
on({ id: EXTERNAL.zaehlerLinksLWT,  change: 'ne' }, () => regelzyklus());
on({ id: EXTERNAL.wrDachOnline,     change: 'ne' }, () => regelzyklus());
on({ id: EXTERNAL.wrFassadeOnline,  change: 'ne' }, () => regelzyklus());

setInterval(regelzyklus, TIMES.regelIntervallSek * 1000);
setInterval(checkPumpScriptVersions, PUMP_SCRIPT_CHECK.intervalMs);

// Countdown aktualisieren (jede Sekunde)
setInterval(() => {
    const now = Date.now();
    const sec = Math.max(0, Math.ceil((_nextRunTs - now) / 1000));
    setState(DP.nextRunInSek, sec, true);
}, 1000);

// Überbrückung Speicherladepumpe: Log mit Status-Spalte (AKTIV / INAKTIV)
on({ id: 'shelly.1.shellyprorgbwwpm#ece334f93c48#1.RGB0.Switch', change: 'ne' }, (obj) => {
    const onBypass = (obj.state && obj.state.val === true);

    if (onBypass) {
        // Neue Log-Meldung bei jeder Aktivierung
        appendLog('Überbrückung der Speicherladepumpe aktiviert – Fernabschaltung nicht möglich, Ansteuerung erfolgt direkt vom Kessel. [BP001]');
        updateLogAckStatus('BP001', 'AKTIV');
    } else {
        // Status in der bestehenden Log-Meldung auf INAKTIV setzen
        updateLogAckStatus('BP001', 'INAKTIV');
    }
});

/* ==========================================================
   9) INITIALISIERUNG
   ========================================================== */

setState(DP.aktiv, false, true);
setState(DP.ackBlink, false, true);
setState(DP.status, 'Initialisierung abgeschlossen. Warte auf PV-Überschuss. [SYS000]', true);
appendLog('SYS000: Initialisierung abgeschlossen');
setTimeout(_flushPendingLog, 1000);

setPWM_Immediate(0);
setState(DP.pwmTargetW, 0, true);

// Countdown initial setzen
_nextRunTs = Date.now() + (TIMES.regelIntervallSek * 1000);
setState(DP.nextRunInSek, TIMES.regelIntervallSek, true);

// Baseline für Event-Trigger setzen
_lastNetzNettoW = (Number(getState(EXTERNAL.ueberschussW)?.val) || 0) - (Number(getState(EXTERNAL.netzverbrauchW)?.val) || 0);

checkPumpScriptVersions();

// Initiale Ampel/Quittieranzeige
updateAmpel();
updateAckBlink();
