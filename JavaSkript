// Umrechnung 0–max → 0–99% (0=aus, 1..99=ein; 100 ist verboten)
function _rawToPercent(rawW) {
    const w = clamp(rawW, 0, LIMITS.maxPowerW);
    if (w <= 0) return 0;

    let percent = Math.round((w / LIMITS.maxPowerW) * 100);
    percent = clamp(percent, 1, 99);
    return percent;
}

function _deviceOnline() {
    try { return getState(EXTERNAL.deviceOnline)?.val === true; } catch { return false; }
}

function _setPWMPercentHW(percent) {
    const online = _deviceOnline();
    if (!online) {
        log('[PWM] Gerät offline – keine Ausgabe', 'warn');
        setState(DP.pwmStatus, 'Gerät offline – PWM deaktiviert (400)', true);

        setState(PWM_DP, 0, true);
        setState(DP.pwmPercent, 0, true);
        return;
    }

    const p = clamp(Math.round(percent), 0, 99);

    setState(PWM_DP, p, true);

    setState(DP.pwmStatus, `PWM: ${p}%`, true);
    setState(DP.pwmPercent, p, true);
}

// Hardware-Ausgabe bei Änderung des gerampten Sollwerts
on({ id: DP.pwmWatt, change: 'ne' }, (obj) => {
    const w = Number(obj.state.val) || 0;
    const percent = _rawToPercent(w);
    _setPWMPercentHW(percent);
});

// Sofort-Setzen (ohne Rampe) für Notfälle/Kalibrierung
function setPWM_Immediate(watt) {
    const w = clamp(Math.round(watt), 0, LIMITS.maxPowerW);
    setState(DP.pwmTargetW, w, true);
    _targetToken++;
    setState(DP.pwmWatt, w, true);
}

// Zielwert setzen (mit Rampe)
function setPWM_TargetWatt(watt) {
    const w = clamp(Math.round(watt), 0, LIMITS.maxPowerW);
    setState(DP.pwmTargetW, w, true);
    _targetToken++;
}

// Ramper – fährt PWM_Watt mit max 100 W/s zum Target
let _lastRampTs = Date.now();
setInterval(() => {
    const now = Date.now();
    const dt = Math.max(0.001, (now - _lastRampTs) / 1000);
    _lastRampTs = now;

    const curr = Number(getState(DP.pwmWatt)?.val) || 0;
    const target = Number(getState(DP.pwmTargetW)?.val) || 0;
    if (curr === target) return;

    const maxStep = RAMP.rateWps * dt;
    let next = curr;
    if (target > curr) next = Math.min(curr + maxStep, target);
    else               next = Math.max(curr - maxStep, target);

    setState(DP.pwmWatt, Math.round(next), true);
}, RAMP.tickMs);

// Gerät Online/Offline → PWM 0 erzwingen / Wiederanlauf
on({ id: EXTERNAL.deviceOnline, change: 'ne' }, (obj) => {
    const online = obj.state.val === true;
    if (!online) {
        setState(PWM_DP, 0, true);
        setState(DP.pwmPercent, 0, true);
        setState(DP.pwmStatus, 'Gerät offline – PWM deaktiviert (400)', true);
    } else {
        const w = Number(getState(DP.pwmWatt)?.val) || 0;
        const percent = _rawToPercent(w);
        _setPWMPercentHW(percent);
    }
});


/* ==========================================================
   5) AMPEL-STEUERUNG (LEDs abhängig vom Regelstatus)
   ========================================================== */

let _ampelBlinkTimer = null;
let _lastAutoLoggedStatus = '';

// LED setzen: interne Anzeige + externe GPIO-DPs
function _led(dp, val) {
    const v = !!val;

    setState(dp, v, true);

    if (dp === DP.ledGruen) setState(LED_GPIO.gruen, v, true);
    if (dp === DP.ledGelb)  setState(LED_GPIO.gelb,  v, true);
    if (dp === DP.ledRot)   setState(LED_GPIO.rot,   v, true);
}

function _ampelReset() {
    _led(DP.ledGruen, false);
    _led(DP.ledGelb, false);
    _led(DP.ledRot, false);
    if (_ampelBlinkTimer) { clearInterval(_ampelBlinkTimer); _ampelBlinkTimer = null; }
}
function _ampelBlink(...dps) {
    let state = false;
    if (_ampelBlinkTimer) clearInterval(_ampelBlinkTimer);
    _ampelBlinkTimer = setInterval(() => {
        state = !state; dps.forEach(dp => _led(dp, state));
    }, TIMES.ampelBlinkMs);
}

function updateAmpel() {
    const status = String(getState(DP.status)?.val || '');

    // Auto-Log für ST/KL/TP-Statuscodes
    if (status !== _lastAutoLoggedStatus && /\[(ST|KL|TP)\d{3}\]/.test(status)) {
        appendLog(status);
        _lastAutoLoggedStatus = status;
    }

    const leistung = Number(getState(DP.pwmWatt)?.val || 0);

    // Soll-Zustand berechnen, ohne sofort zu schalten (verhindert Flackern)
    let wantGreen = false;
    let wantYellow = false;
    let wantRed = false;
    let wantBlink = false;

    if (_pwmFaultActive) {
        wantRed = true;
    } else if (status.includes('[TP002]') || status.includes('[TP001]') || status.includes('Übertemperatur')) {
        wantRed = true;
    } else if (status.includes('[ABW001]') || status.includes('[FI001]')) {
    wantRed = true;
} else if (status.includes('[TP003]')) {
        wantGreen = true;
        wantYellow = true;
    } else if (status.includes('[RG003]') && leistung > 0) {
        wantYellow = true;
    } else if (status.includes('[RG001]')) {
        // Regelung manuell deaktiviert -> alle LEDs AUS
        wantGreen = false;
        wantYellow = false;
        wantRed = false;
    } else if (status.includes('[RG004]')) {
        // Standby (nur wenn erlaubt)
        wantGreen = (getState(DP.standbyBlinkEnable)?.val === true);
    } else if (status.includes('[ST001]')) {
        wantBlink = true;
    }

    // Blink-Fall
    if (wantBlink) {
        _ampelBlink(DP.ledGruen, DP.ledGelb, DP.ledRot);
        return;
    }

    // Kein Blink-Fall → evtl. alten Blinktimer stoppen
    if (_ampelBlinkTimer) {
        clearInterval(_ampelBlinkTimer);
        _ampelBlinkTimer = null;
    }

    // Nur schalten, wenn sich der Zustand ändert
    if (getState(DP.ledGruen)?.val !== wantGreen) _led(DP.ledGruen, wantGreen);
    if (getState(DP.ledGelb)?.val !== wantYellow) _led(DP.ledGelb, wantYellow);
    if (getState(DP.ledRot)?.val !== wantRed) _led(DP.ledRot, wantRed);

    return;
}

/* ---- Quittiertaster-Blinken (eigener DP) ---- */
let _ackBlinkTimer = null;
let _ackBlinkOverride = false;

function _setAckBlink(val) {
    setState(DP.ackBlink, !!val, true);
}

function stopAckBlink() {
    if (_ackBlinkTimer) {
        clearInterval(_ackBlinkTimer);
        _ackBlinkTimer = null;
    }
    _setAckBlink(false);
}

function startAckBlinkSlow() {
    if (_ackBlinkOverride) return;
    if (_ackBlinkTimer) return;

    let state = false;
    _ackBlinkTimer = setInterval(() => {
        state = !state;
        _setAckBlink(state);
    }, 700);
}

function flashAckBlink(times = 3, periodMs = 200) {
    if (_ackBlinkTimer) {
        clearInterval(_ackBlinkTimer);
        _ackBlinkTimer = null;
    }
    _ackBlinkOverride = true;
    _setAckBlink(false);

    let toggles = times * 2;
    let state = false;

    const t = setInterval(() => {
        state = !state;
        _setAckBlink(state);
        toggles -= 1;

        if (toggles <= 0) {
            clearInterval(t);
            _ackBlinkOverride = false;
            _setAckBlink(false);
            updateAckBlink();
        }
    }, periodMs);
}

/* ==========================================================
   5a) MULTI-FEHLER-STATUS (robust)
   ========================================================== */

// Aktive quittierungspflichtige Fehler (TP004/ABW001) + nicht manuelle (PWM400/PWMERR)
// Map: code -> { status, sinceTs }
const _activeFaults = new Map();
let _abwAutoQuittTimer = null;
let _abwAutoQuittAttemptTs = 0; // Zeitpunkt des ersten Auto-Quittier-Versuchs

function _clearAbwAutoQuittTimer() {
    if (_abwAutoQuittTimer) clearTimeout(_abwAutoQuittTimer);
    _abwAutoQuittTimer = null;
}

function _scheduleAbwAutoQuitt() {
    _clearAbwAutoQuittTimer();
    _abwAutoQuittTimer = setTimeout(() => {
        _abwAutoQuittTimer = null;
        if (!_activeFaults.has('ABW001')) return;
        const st = _activeFaults.get('ABW001')?.status;
        if (st !== ACK_STATUS.QUITTIERBAR) return;

        _abwAutoQuittAttemptTs = Date.now();
        clearFault('ABW001');
        appendLog('ABW001 wurde nach 15 min automatisch quittiert (erster Auto-Quittier-Versuch).');

        if (_activeFaults.size === 0) {
            _sperreAktiv = false;
            setState(DP.status, 'ABW001 nach 15 min automatisch quittiert (erster Versuch).', true);
            log('[Heizstab] ABW001 automatisch quittiert (erster Versuch). Sperre aufgehoben.', 'info');
        } else {
            setState(DP.status, 'ABW001 nach 15 min automatisch quittiert (erster Versuch). Weitere Fehler aktiv.', true);
            log('[Heizstab] ABW001 automatisch quittiert (erster Versuch), aber weitere Fehler aktiv.', 'warn');
        }
        updateAckBlink();
    }, TIMES.abwAutoQuittDelayMs);
}

function setFaultActive(code, status) {
    if (!code || !status) return;
    const prev = _activeFaults.get(code);
    if (!prev) {
        _activeFaults.set(code, { status, sinceTs: Date.now() });
    } else {
        _activeFaults.set(code, { ...prev, status });
    }
    updateLogAckStatus(code, status);

    if (code === 'ABW001') {
        const now = Date.now();
        const recurrenceActive =
            _abwAutoQuittAttemptTs > 0 &&
            (now - _abwAutoQuittAttemptTs) <= TIMES.abwRecurrenceWindowMs;

        if (recurrenceActive) {
            appendLog('ABW001 erneut innerhalb 15 min nach Auto-Quittierung aufgetreten – manuelle Quittierung erforderlich (erster Auto-Versuch wurde bereits durchgeführt).');
            setState(DP.status, 'Abweichung erneut innerhalb 15 min nach Auto-Quittierung. Manuelle Quittierung erforderlich. [ABW001]', true);
            _clearAbwAutoQuittTimer();
        } else {
            _scheduleAbwAutoQuitt();
        }
    }
}

function clearFault(code) {
    if (!code) return;
    if (_activeFaults.has(code)) {
        _activeFaults.delete(code);
    }
    if (code === 'ABW001') {
        _clearAbwAutoQuittTimer();
    }
    // Log-Eintrag (falls vorhanden) als quittiert markieren
    updateLogAckStatus(code, ACK_STATUS.QUITTIERT);
}

function hasNonQuittierbarFault() {
    for (const [, v] of _activeFaults.entries()) {
        if (v?.status === ACK_STATUS.NICHT_QUITTIERBAR) return true;
    }
    return false;
}

function hasQuittierbarFault() {
    for (const [, v] of _activeFaults.entries()) {
        if (v?.status === ACK_STATUS.QUITTIERBAR) return true;
    }
    return false;
}

// dynamische Status-Updates (z.B. TP004 wird quittierbar sobald Temperatur ok)
function refreshDynamicFaultStatuses() {
    if (_activeFaults.has('TP004')) {
        setFaultActive('TP004', _currentAckStatusFor('TP004'));
    }
    if (_activeFaults.has('PWM400')) {
        setFaultActive('PWM400', _currentAckStatusFor('PWM400'));
    }
    if (_activeFaults.has('FI001')) {
    setFaultActive('FI001', _currentAckStatusFor('FI001'));
}
    if (_activeFaults.has('PWMERR')) {
        setFaultActive('PWMERR', _currentAckStatusFor('PWMERR'));
    }
}

function updateAckBlink() {
    if (_ackBlinkOverride) return;

    refreshDynamicFaultStatuses();

    // Blink nur wenn es mind. einen quittierbaren Fehler gibt und KEIN nicht-quittierbarer parallel aktiv ist
    if (hasQuittierbarFault() && !hasNonQuittierbarFault()) {
        startAckBlinkSlow();
    } else {
        stopAckBlink();
    }
}

// Status-Reaktion
on({ id: DP.status, change: 'any' }, () => updateAmpel());
on({ id: DP.standbyBlinkEnable, change: 'ne' }, () => updateAmpel());


