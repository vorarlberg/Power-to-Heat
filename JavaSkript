/**
 * ABW0001-Quittierungslogik
 *
 * Ablauf:
 * 1) Bei erstem Auftreten von ABW0001 wird nach 15 Minuten automatisch quittiert.
 * 2) Tritt ABW0001 innerhalb der folgenden 15 Minuten erneut auf,
 *    bleibt der Heizstab gesperrt bis zur manuellen Quittierung.
 * 3) Meldetext und Log enthalten den Hinweis, dass beim ersten Mal
 *    eine automatische Quittierung versucht wurde.
 */

// ==================== KONFIGURATION (Datenpunkte & Zeiten) ====================
const CFG = {
    dp: {
        statusCode: '0_userdata.0.Heizung.PowerToHeat.StatusCode',
        manualQuitt: '0_userdata.0.Heizung.PowerToHeat.Quittierung',
        autoQuittCmd: '0_userdata.0.Heizung.PowerToHeat.AutoQuittieren',
        heizstabFreigabe: '0_userdata.0.Heizung.PowerToHeat.HeizstabFreigabe',
        meldung: '0_userdata.0.Heizung.PowerToHeat.Meldung',

        // interne/ausgabe DPs (read-only)
        firstErrorTs: '0_userdata.0.Heizung.PowerToHeat.ABW0001.ErstauftretenTs',
        autoQuittTried: '0_userdata.0.Heizung.PowerToHeat.ABW0001.AutoQuittVersucht',
        watchUntilTs: '0_userdata.0.Heizung.PowerToHeat.ABW0001.WatchUntilTs',
        lockManual: '0_userdata.0.Heizung.PowerToHeat.ABW0001.ManuelleQuittErforderlich'
    },
    times: {
        autoQuittDelayMin: 15,
        reoccurWindowMin: 15
    },
    code: 'ABW0001'
};

// ==================== DATENPUNKTE ANLEGEN ====================
createState(CFG.dp.firstErrorTs, 0, { name: 'ABW0001 Erstauftreten (Epoch ms)', type: 'number', role: 'value.time', read: true, write: false });
createState(CFG.dp.autoQuittTried, false, { name: 'ABW0001 Auto-Quittierung versucht', type: 'boolean', role: 'indicator', read: true, write: false });
createState(CFG.dp.watchUntilTs, 0, { name: 'ABW0001 Überwachungsfenster bis (Epoch ms)', type: 'number', role: 'value.time', read: true, write: false });
createState(CFG.dp.lockManual, false, { name: 'ABW0001 manuelle Quittierung erforderlich', type: 'boolean', role: 'indicator.alarm', read: true, write: false });

// ==================== HILFSFUNKTIONEN ====================
let autoQuittTimer = null;
let lastAbwActive = false;

function nowMs() {
    return Date.now();
}

function minutesToMs(min) {
    return min * 60 * 1000;
}

function setMeldung(text) {
    setState(CFG.dp.meldung, text, true);
    log(text, 'warn');
}

function isAbw0001Active() {
    const s = getState(CFG.dp.statusCode);
    return !!s && s.val === CFG.code;
}

function clearAutoTimer() {
    if (autoQuittTimer) {
        clearTimeout(autoQuittTimer);
        autoQuittTimer = null;
    }
}

function scheduleAutoQuitt(firstTs) {
    clearAutoTimer();
    const dueAt = firstTs + minutesToMs(CFG.times.autoQuittDelayMin);
    const waitMs = Math.max(0, dueAt - nowMs());

    autoQuittTimer = setTimeout(() => {
        autoQuittTimer = null;

        if (!isAbw0001Active()) {
            return;
        }
        if (!!getState(CFG.dp.lockManual).val || !!getState(CFG.dp.autoQuittTried).val) {
            return;
        }

        setState(CFG.dp.autoQuittCmd, true, false);
        setState(CFG.dp.autoQuittTried, true, true);
        setState(CFG.dp.watchUntilTs, nowMs() + minutesToMs(CFG.times.reoccurWindowMin), true);
        setMeldung('ABW0001: Erste automatische Quittierung wurde versucht. Überwache 15 Minuten auf Wiederauftreten.');
    }, waitMs);
}

function resetAbwTracking() {
    clearAutoTimer();
    setState(CFG.dp.firstErrorTs, 0, true);
    setState(CFG.dp.autoQuittTried, false, true);
    setState(CFG.dp.watchUntilTs, 0, true);
    setState(CFG.dp.lockManual, false, true);
}

function handleStatusTransition() {
    const abwActive = isAbw0001Active();
    const risingEdge = abwActive && !lastAbwActive;
    const fallingEdge = !abwActive && lastAbwActive;

    if (risingEdge) {
        const manualLock = !!getState(CFG.dp.lockManual).val;
        const autoTried = !!getState(CFG.dp.autoQuittTried).val;
        const watchUntil = getState(CFG.dp.watchUntilTs).val || 0;

        if (manualLock) {
            setState(CFG.dp.heizstabFreigabe, false, false);
            lastAbwActive = abwActive;
            return;
        }

        if (autoTried && nowMs() <= watchUntil) {
            setState(CFG.dp.lockManual, true, true);
            setState(CFG.dp.heizstabFreigabe, false, false);
            setMeldung('ABW0001 innerhalb 15 Minuten erneut aufgetreten. Heizstab bleibt aus bis zur manuellen Quittierung (erste Auto-Quittierung wurde bereits versucht).');
            lastAbwActive = abwActive;
            return;
        }

        if (!autoTried) {
            const firstTs = nowMs();
            setState(CFG.dp.firstErrorTs, firstTs, true);
            setMeldung('ABW0001 erkannt. Automatische Quittierung in 15 Minuten geplant.');
            scheduleAutoQuitt(firstTs);
        }
    }

    if (fallingEdge) {
        clearAutoTimer();
    }

    lastAbwActive = abwActive;
}

function unlockAfterManualQuittierung() {
    resetAbwTracking();
    setState(CFG.dp.heizstabFreigabe, true, false);
    setMeldung('ABW0001 quittiert. Heizstab wieder freigegeben.');
}

// ==================== EVENTS ====================
on({ id: CFG.dp.statusCode, change: 'ne' }, handleStatusTransition);

on({ id: CFG.dp.manualQuitt, val: true }, () => {
    unlockAfterManualQuittierung();
    setState(CFG.dp.manualQuitt, false, true);
});

// ==================== INIT ====================
lastAbwActive = isAbw0001Active();
if (lastAbwActive && !getState(CFG.dp.autoQuittTried).val && !getState(CFG.dp.lockManual).val) {
    let firstTs = getState(CFG.dp.firstErrorTs).val || 0;
    if (!firstTs) {
        firstTs = nowMs();
        setState(CFG.dp.firstErrorTs, firstTs, true);
    }
    scheduleAutoQuitt(firstTs);
}

onStop(() => {
    clearAutoTimer();
}, 200);
